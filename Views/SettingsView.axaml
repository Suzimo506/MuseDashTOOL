<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:conv="using:MdModManager.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MdModManager.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             DragDrop.AllowDrop="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <conv:StringToFontFamilyConverter x:Key="FontFamilyConverter" />
        <!-- 纯图标按钮主题 -->
        <ControlTheme x:Key="RobustPlainIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
        </ControlTheme>

        <!-- 小型圆角按钮主题 (彻底隔离影响，纯透明背景) -->
        <ControlTheme x:Key="SmallRoundBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>

        <!-- 透明效果选项按钮 (ToggleButton 风格，透明背景隔离) -->
        <ControlTheme x:Key="TranspOptionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="Transparent"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>

        <!-- 滑动条禁用态重写：提升深色模式可见度 -->
        <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#555555"/>
        <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="#777777"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="#888888"/>
    </UserControl.Resources>

    <Panel>
        <!-- ══════════════════════════════════════════════════════
             主设置面板 (IsColorPanelVisible = false 时显示)
             ══════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsMainPanelVisible}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="30" Margin="20">

                    <!-- 标题行：左侧标题 + 右侧功能按钮组 -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="设置" FontSize="28" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#FF00FF" Offset="0"/>
                                    <GradientStop Color="#FF69B4" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Grid>

                    <!-- 设置列表 -->
                    <Grid ColumnDefinitions="Auto, 20, *"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="15">

                        <!-- 1. 自动翻译 -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="自动翻译至中文"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="0" Grid.Column="2"
                                  IsChecked="{Binding AutoTranslateDescriptions}"
                                  VerticalAlignment="Center"/>

                        <!-- 1.5 以原版启动游戏 -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="以原版启动游戏"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="1" Grid.Column="2"
                                  IsChecked="{Binding IsOriginalModeEnabled}"
                                  VerticalAlignment="Center"/>

                        <!-- 1.6 隐藏控制台 -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="启动游戏时隐藏控制台"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="2" Grid.Column="2"
                                  IsChecked="{Binding HideConsoleOnLaunch}"
                                  VerticalAlignment="Center"/>

                        <!-- 2. 不兼容 Mod 提醒 -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="下载不兼容 Mod 时不再提醒"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="3" Grid.Column="2"
                                  IsChecked="{Binding SuppressIncompatibleModWarning}"
                                  VerticalAlignment="Center"/>

                        <!-- 3. 删除确认弹窗 -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="删除时不再显示确认弹窗"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="4" Grid.Column="2"
                                  IsChecked="{Binding SuppressDeleteConfirmation}"
                                  VerticalAlignment="Center"/>

                        <!-- 4. 谱面名称滚动 -->
                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Text="谱面名称过长时滚动显示"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="5" Grid.Column="2"
                                  IsChecked="{Binding EnableChartNameMarquee}"
                                  VerticalAlignment="Center"/>

                        <!-- 5. 启动游戏确认弹窗 -->
                        <TextBlock Grid.Row="6" Grid.Column="0"
                                   Text="启动/重启游戏时不再显示确认弹窗"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <CheckBox Grid.Row="6" Grid.Column="2"
                                  IsChecked="{Binding SuppressLaunchGameConfirmation}"
                                  VerticalAlignment="Center"/>

                        <!-- 6. 下载源 -->
                        <TextBlock Grid.Row="7" Grid.Column="0"
                                   Text="整合包与MelonLoader下载源"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <ComboBox Grid.Row="7" Grid.Column="2"
                                  ItemsSource="{Binding DownloadSources}"
                                  SelectedItem="{Binding SelectedDownloadSource}"
                                  Foreground="{DynamicResource ThemeTextMainBrush}"
                                  Width="180" HorizontalContentAlignment="Left"/>

                        <!-- 7. 谱面试听音量 -->
                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="谱面试听音量"
                                   FontSize="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <Slider Grid.Row="8" Grid.Column="2"
                                Width="200" HorizontalAlignment="Left"
                                Minimum="0" Maximum="1"
                                Value="{Binding ChartPreviewVolume}"
                                VerticalAlignment="Center"/>
                                
                        <!-- 8. 高级设置 -->
                        <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3"
                                Command="{Binding OpenAdvancedPanelCommand}"
                                Theme="{StaticResource RobustPlainIconBtn}"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="扩展设置">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Viewbox Width="20" Height="20">
                                    <Canvas Width="1024" Height="1024">
                                        <Path Fill="{DynamicResource SvgIconBrush}" Data="M976 384l-12.8 19.2-83.2 108.8 9.728 14.272a287.36 287.36 0 0 0-81.664-14.144 68.608 68.608 0 0 1 14.336-44.928l76.8-102.4c-12.8-44.8-38.4-83.2-70.4-121.6l-128 12.8c-32 6.4-57.6-12.8-70.4-38.4l-51.2-115.2c-25.6-6.4-44.8-6.4-70.4-6.4-25.6 0-44.8 0-70.4 6.4l-51.2 115.2c-12.8 25.6-38.4 44.8-70.4 38.4l-128-12.8c-32 38.4-51.2 76.8-70.4 128l76.8 102.4c19.2 25.6 19.2 57.6 0 83.2l-76.8 102.4c12.8 44.8 38.4 83.2 70.4 121.6l128-12.8c32-6.4 57.6 12.8 70.4 38.4l51.2 115.2c25.6 6.4 44.8 6.4 70.4 6.4 11.904 0 22.4 0 32.832-0.64 10.112 20.48 22.528 39.552 37.056 56.96a414.08 414.08 0 0 1-76.288 7.68c-32 0-70.4-6.4-102.4-12.8l-19.2-6.4-6.4-12.8-51.2-128-153.6 19.2-12.8-12.8c-44.8-57.6-83.2-115.2-102.4-185.6l-6.4-19.2 6.4-12.8L137.6 512 48 390.4l6.4-19.2c19.2-70.4 51.2-134.4 102.4-185.6l12.8-12.8 147.2 19.2 64-140.8 25.6-6.4c32-6.4 64-12.8 102.4-12.8 38.4 0 70.4 6.4 102.4 12.8h25.6l64 140.8 153.6-19.2 12.8 12.8c44.8 57.6 83.2 115.2 102.4 185.6l6.4 19.2z" />
                                        <Path Fill="{DynamicResource SvgIconBrush}" Data="M1024 814.912c0 16.64-13.632 29.888-29.696 29.888h-36.224a155.52 155.52 0 0 1-15.296 36.096l25.984 26.112c11.52 11.648 11.968 30.272 0.384 42.304l-21.376 21.568a30.208 30.208 0 0 1-42.496 0l-26.368-26.496c-10.688 5.76-22.272 10.368-33.792 13.632v36.096a30.272 30.272 0 0 1-30.08 29.888h-29.696a29.632 29.632 0 0 1-29.632-29.888v-36.096a152.448 152.448 0 0 1-35.072-14.464l-27.2 27.328a30.208 30.208 0 0 1-42.432 0l-21.44-21.12a30.208 30.208 0 0 1-0.384-42.304l27.584-27.84a159.36 159.36 0 0 1-14.4-34.816h-36.672A29.632 29.632 0 0 1 576 814.912v-29.824c0-16.64 13.184-29.888 29.696-29.888h36.224c3.328-11.648 7.872-23.232 13.632-34.048l-26.368-26.496a30.208 30.208 0 0 1-0.448-42.304l21.44-21.568a30.208 30.208 0 0 1 42.432 0l25.984 26.112c11.52-6.656 23.488-11.648 36.288-14.912v-36.096c0-16.64 13.184-29.888 29.632-29.888h30.528c16.512 0 29.696 13.248 29.696 29.888v36.096c12.352 3.264 23.872 8.32 35.008 14.464l25.6-25.28a30.208 30.208 0 0 1 42.432 0l21.44 21.12c11.52 11.648 11.904 30.72 0.384 42.368l-0.448 0.384-25.536 25.344c6.208 11.2 11.136 22.784 14.464 34.816h36.224c16.512 0 29.696 13.248 29.696 29.888v29.824zM800.192 710.4a89.6 89.6 0 0 0 0 179.2 89.6 89.6 0 0 0 0-179.2zM508.8 710.4c5.952 0 11.84-0.256 17.664-0.768 8.768-26.56 21.312-51.456 36.992-73.92a140.864 140.864 0 0 1-54.656 10.688c-76.8 0-134.4-64-134.4-134.4 0-76.8 57.6-134.4 134.4-134.4 76.8 0 134.4 64 134.4 134.4 0 19.2-3.584 37.12-10.176 53.312 22.4-15.936 47.104-28.8 73.6-37.824A199.424 199.424 0 0 0 508.8 313.6C399.936 313.6 310.336 403.2 310.336 512c0 108.8 89.6 198.4 198.4 198.4z" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="高级设置" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </StackPanel>
                        </Button>

                        <!-- 9. 调整界面样式 -->
                        <Button Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3"
                                Command="{Binding OpenColorPanelCommand}"
                                Theme="{StaticResource RobustPlainIconBtn}"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="进入界面颜色 / 外观设置">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="调整界面样式" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             颜色子面板 (IsColorPanelVisible = true 时显示)
             ══════════════════════════════════════════════════════ -->
        <!-- Added ScrollViewer inside the Color Panel -->
        <Grid IsVisible="{Binding IsColorPanelVisible}">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel Spacing="22" Margin="20">

                <!-- 顶部栏：返回按钮 + 标题 + 右侧操作按钮组 -->
                <Grid ColumnDefinitions="Auto,*,Auto">

                    <!-- 左上角：返回按钮 -->
                    <Button Grid.Column="0"
                            Command="{Binding CloseColorPanelCommand}"
                            Theme="{StaticResource SmallRoundBtn}"
                            ToolTip.Tip="返回设置">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <!-- New SVG back arrow icon -->
                            <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                                  Fill="{DynamicResource SvgIconBrush}" Stretch="Uniform" Width="22" Height="22" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- (Removed Title TextBlock) -->
                    <!-- 右上角：主题切换 + 导入图片 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">

                        <Button Command="{Binding ToggleThemeCommand}"
                                Theme="{StaticResource SmallRoundBtn}"
                                ToolTip.Tip="切换深色/浅色主题">
                            <PathIcon Data="{Binding ThemeToggleIconData}"
                                      Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18" />
                        </Button>

                        <Button Command="{Binding SelectBackgroundImageCommand}"
                                Theme="{StaticResource SmallRoundBtn}"
                                ToolTip.Tip="鼠标左键：导入自定义背景图片&#x0a;鼠标右键：清除背景图片"
                                PointerReleased="OnImportImagePointerReleased">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M737.7 447.9c-51.9 0-95.9-44-95.9-95.9 0-52 44-96 95.9-96 52 0 96 44 96 96-0.1 51.9-44 95.9-96 95.9z m168-319.8c32 0 55.9 23.9 55.9 56v655.6c0 32-23.9 55.9-55.9 55.9H122c-32.1 0-56-24-56-55.9V184c0-32.1 23.9-56 56-56l783.7 0.1zM699.6 523.9l198 211.8V215.9c0-13.9-12-23.9-26.1-23.9H155.9c-14 0-24 10.1-26 23.9v519.8L381.8 432c8-8.1 20-16 34-16 13.9 0 25.9 4 34 14l108 118 8 7.8c6 4 13.9 8 22 8 8 0 16-4 23.9-10l36.1-32c7.9-6 15.9-10 25.9-10 10 0.1 20 4.1 25.9 12.1z"
                                      Foreground="{DynamicResource SvgIconBrush}" Width="14" Height="14"/>
                                <TextBlock Text="导入图片" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ─── 分组：透明窗口效果 ─── -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16,12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="透明窗口效果"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">

                            <!-- 无效果 -->
                            <Button Command="{Binding SetTransparencyModeCommand}"
                                    CommandParameter="None"
                                    Theme="{StaticResource TranspOptionBtn}">
                                <TextBlock Text="⬛ 无效果"
                                           Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </Button>



                            <!-- 全透明 -->
                            <Button Command="{Binding SetTransparencyModeCommand}"
                                    CommandParameter="Transparent"
                                    Theme="{StaticResource TranspOptionBtn}">
                                <TextBlock Text="💨 全透明"
                                           Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </Button>

                            <!-- Mica（云母）Windows 11 -->
                            <Button Command="{Binding SetTransparencyModeCommand}"
                                    CommandParameter="Mica"
                                    Theme="{StaticResource TranspOptionBtn}"
                                    ToolTip.Tip="采样桌面壁纸颜色模糊，性能极佳，需要 Windows 11">
                                <TextBlock Text="🪨 Mica"
                                           Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </Button>

                            <!-- Acrylic（亚克力） -->
                            <Button Command="{Binding SetTransparencyModeCommand}"
                                    CommandParameter="AcrylicBlur"
                                    Theme="{StaticResource TranspOptionBtn}"
                                    ToolTip.Tip="抓取窗口下方所有元素（含其他窗口）进行模糊">
                                <TextBlock Text="🫧 Acrylic"
                                           Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </Button>

                        </StackPanel>

                        <!-- 当前选择状态提示 -->
                        <TextBlock FontSize="12" Opacity="0.6"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"
                                   Text="{Binding TransparencyModeDisplayName, StringFormat='当前效果：{0}'}"/>
                    </StackPanel>
                </Border>

                <!-- ─── 分组：背景亮度 / 左侧按键字体横向间隔 ─── -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16,12">
                    <Grid ColumnDefinitions="*, 20, *">
                        <!-- 左半边：背景亮度 -->
                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="背景亮度"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            <Grid ColumnDefinitions="*,50">
                                <Slider Grid.Column="0"
                                        Minimum="0.05" Maximum="1.0"
                                        Value="{Binding CustomBackgroundOpacity}"
                                        IsEnabled="{Binding HasBackgroundImage}"
                                        TickFrequency="0.01"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                           FontSize="13">
                                    <TextBlock.Text>
                                        <Binding Path="CustomBackgroundOpacity" StringFormat="{}{0:P0}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <!-- 分割线 -->
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="0,5"/>

                        <!-- 右半边：左侧按键字体横向间隔 -->
                        <StackPanel Grid.Column="2" Spacing="10">
                            <TextBlock Text="左侧按键字体横向间隔"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            <Grid ColumnDefinitions="*,50">
                                <Slider Grid.Column="0"
                                        Minimum="0" Maximum="20"
                                        Value="{Binding NavButtonLetterSpacing}"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                           FontSize="13" Text="{Binding NavButtonLetterSpacing, StringFormat={}{0:F0}}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── 分组：背景不透明度 / 背景模糊程度 ─── -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16,12">
                    <Grid ColumnDefinitions="*, 20, *">
                        <!-- 左半边：背景透明度 (原窗口透明度) -->
                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="背景不透明度"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            <Grid ColumnDefinitions="*,50">
                                <Slider Grid.Column="0"
                                        Minimum="0.1" Maximum="1.0"
                                        Value="{Binding WindowOpacity}"
                                        IsEnabled="{Binding IsWindowOpacityEnabled}"
                                        TickFrequency="0.01"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                           FontSize="13">
                                    <TextBlock.Text>
                                        <Binding Path="WindowOpacity" StringFormat="{}{0:P0}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <!-- 分割线 -->
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="0,5"/>

                        <!-- 右半边：背景模糊程度 -->
                        <StackPanel Grid.Column="2" Spacing="10">
                            <TextBlock Text="背景模糊程度"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            <Grid ColumnDefinitions="*,50">
                                <Slider Grid.Column="0"
                                        Minimum="0" Maximum="50"
                                        Value="{Binding BackgroundBlurRadius}"
                                        IsEnabled="{Binding HasBackgroundImage}"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                           FontSize="13" Text="{Binding BackgroundBlurRadius, StringFormat={}{0:F0}}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── 分组：字体选择 ─── -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16,12">
                    <Grid ColumnDefinitions="*, 20, *">
                        <!-- 左半边：字体选择与预览 -->
                        <StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="界面字体"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                       VerticalAlignment="Center"/>
                            <Grid ColumnDefinitions="1.5*,Auto,*" ColumnSpacing="15">
                                <ComboBox Grid.Column="0" 
                                          ItemsSource="{Binding AvailableFonts}" 
                                          SelectedIndex="{Binding SelectedFontIndex}" 
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource ControlBgBrush}"
                                          Foreground="{DynamicResource ThemeTextMainBrush}"
                                          BorderThickness="1"
                                          BorderBrush="{DynamicResource ThemeTextSubBrush}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" 
                                                       FontFamily="{Binding Converter={StaticResource FontFamilyConverter}}"
                                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                                       FontSize="14" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                           Text="Preview预览123" TextAlignment="Left"
                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                           FontSize="14" TextTrimming="CharacterEllipsis">
                                    <TextBlock.FontFamily>
                                        <Binding Path="CustomFontFamily"/>
                                    </TextBlock.FontFamily>
                                </TextBlock>
                                <Button Grid.Column="2"
                                        Command="{Binding ImportFontCommand}"
                                        Theme="{StaticResource RobustPlainIconBtn}"
                                        ToolTip.Tip="支持导入zip、ttf、otf、tte等字体文件格式"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <PathIcon Data="M563.2 42.666667v640c0 23.466667-19.2 42.666667-42.666667 42.666666s-42.666667-19.2-42.666666-42.666666V42.666667c0-23.466667 19.2-42.666667 42.666666-42.666667s42.666667 19.2 42.666667 42.666667 M806.1952 457.275733L550.5792 712.900267a42.7776 42.7776 0 0 1-60.330667 0c-16.597333-16.605867-16.597333-43.776 0-60.330667l255.616-255.624533a42.7776 42.7776 0 0 1 60.330667 0 42.7776 42.7776 0 0 1 0 60.330666 M490.350933 712.8832L234.734933 457.275733a42.7776 42.7776 0 0 1 0-60.330666c16.597333-16.605867 43.776-16.605867 60.330667 0l255.616 255.616a42.7776 42.7776 0 0 1 0 60.330666 42.7776 42.7776 0 0 1-60.330667 0 M904.533333 1024H136.533333c-70.570667 0-128-57.429333-128-128V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666667 42.666667v256c0 23.552 19.114667 42.666667 42.666666 42.666667h768c23.552 0 42.666667-19.114667 42.666667-42.666667V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666666 42.666667v256c0 70.570667-57.429333 128-128 128" 
                                              Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- 中间：分割线 -->
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="0,5"/>

                        <!-- 右半边：字体大小调整 -->
                        <StackPanel Grid.Column="2" Spacing="10" VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock Text="字体大小"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Slider Grid.Column="0" Minimum="12" Maximum="17" Value="{Binding CustomFontSize}" 
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CustomFontSize, StringFormat='\{0\}'}" 
                                           Foreground="{DynamicResource ThemeTextMainBrush}"
                                           FontSize="14" VerticalAlignment="Center" Width="20" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── 分组：文本颜色 ─── -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="文本颜色"
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding OpenHexColorHelpCommand}"
                                    Background="Transparent" BorderThickness="0" Padding="0"
                                    Margin="5,2,0,0" VerticalAlignment="Bottom">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Button.Styles>
                                <TextBlock Text="不知道什么是十六进制颜色？" 
                                           FontSize="11" Opacity="0.6"
                                           TextDecorations="Underline"
                                           Foreground="{DynamicResource ThemeTextMainBrush}"/>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" MinHeight="30">
                            <TextBlock Text="左侧栏按键颜色"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                            <TextBox Text="{Binding CustomThemeTextColor}"
                                     Watermark="#FFFFFF"
                                     Width="100" Height="30"
                                     Padding="8,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"/>

                            <Control Width="1" Margin="10,5"/>

                            <TextBlock Text="右侧面板文本颜色"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                            <TextBox Text="{Binding RightPanelTextColor}"
                                     Watermark="#FFFFFF"
                                     Width="100" Height="30"
                                     Padding="8,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"/>
                                     
                            <Control Width="1" Margin="10,5"/>

                            <TextBlock Text="主题颜色"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                            <TextBox Text="{Binding CustomThemeColor}"
                                     Watermark="#d4237a"
                                     Width="100" Height="30"
                                     Padding="8,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"/>

                            <!-- 一键清除按键 -->
                            <Button Command="{Binding ResetColorsCommand}"
                                    Width="30" Height="30"
                                    Margin="15,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="5"
                                    ToolTip.Tip="一键重置所有自定义颜色">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M886.401 395.097h-251.7V80.614c0-22.091-19.899-40-44.447-40H439.148c-24.547 0-44.447 17.909-44.447 40v314.483h-251.7c-22.315 0-40.404 17.909-40.404 40v506.471c0 22.091 18.09 40 40.404 40h743.4c22.315 0 40.404-17.909 40.404-40V435.097c0.001-22.092-18.089-40-40.404-40z m-10.72 536.47h-127.98V831c0-17.673-12.088-32-27-32s-27 14.327-27 32v100.567h-152V792c0-14.912-12.088-27-27-27s-27 12.088-27 27v139.567h-152V831c0-17.673-12.088-32-27-32s-27 14.327-27 32v100.567H152.597V688.332h723.084v243.235z m0-293.235H152.597V445.097h291.882V90.614h137.819v354.483H875.68v193.235z" 
                                          Foreground="{DynamicResource SvgIconBrush}"/>
                            </Button>

                            <!-- 一键撤回按键 -->
                            <Button Command="{Binding UndoColorsCommand}"
                                    Width="30" Height="30"
                                    Margin="5,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="5"
                                    ToolTip.Tip="撤回一键清除">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M704 352H173.4l137.3-137.4a32 32 0 0 0-45.2-45.2L73.9 360.9a32 32 0 0 0 0 45.8l191.4 191.9a32 32 0 1 0 45.3-45.3L173.3 416H704a192 192 0 0 1 0 384h-320a32 32 0 1 0 0 64h320a256 256 0 0 0 0-512z" 
                                          Foreground="{DynamicResource SvgIconBrush}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             高级设置面板 (IsAdvancedPanelVisible = true 时显示)
             ══════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsAdvancedPanelVisible}">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel Spacing="22" Margin="20">
                    
                    <!-- 顶部栏：返回按钮 + 标题 -->
                    <Grid ColumnDefinitions="Auto, 10, *">
                        <!-- 左方：返回按钮 -->
                        <Button Grid.Column="0" HorizontalAlignment="Left"
                                Command="{Binding CloseAdvancedPanelCommand}"
                                Theme="{StaticResource SmallRoundBtn}"
                                ToolTip.Tip="返回设置">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                                      Fill="{DynamicResource SvgIconBrush}" Stretch="Uniform" Width="22" Height="22" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Column="2" Text="高级设置" FontSize="28" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#d4237a" Offset="0"/>
                                    <GradientStop Color="#FF69B4" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Grid>
                    
                    <!-- ─── 分组：自定义 IP 设置 ─── -->
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16,12">
                        <StackPanel Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="自定义优选 IP"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextMainBrush}"/>
                                        <!-- 显示当前正在使用的 IP -->
                                        <TextBlock Text="{Binding CurrentEffectiveIp, StringFormat='(当前使用: {0})'}"
                                                   FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,2"
                                                   Foreground="{DynamicResource ThemeTextSubBrush}"
                                                   IsVisible="{Binding UseOptimizedIps}"/>
                                    </StackPanel>
                                    <TextBlock Text="开启后，高速 DNS 将不再进行测序竞速，而是强制使用下方输入的 IP"
                                               FontSize="12" Opacity="0.6"
                                               Foreground="{DynamicResource ThemeTextMainBrush}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" 
                                          IsChecked="{Binding UseCustomIp}"
                                          VerticalAlignment="Top"/>
                            </Grid>

                            <Separator Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.1" Height="1"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBox Width="320"
                                         HorizontalAlignment="Left"
                                         Text="{Binding CustomIpAddress}"
                                         Watermark="例如: 104.16.160.1"
                                         IsEnabled="{Binding UseCustomIp}"
                                         Height="36"
                                         VerticalContentAlignment="Center"
                                         Foreground="{DynamicResource ThemeTextMainBrush}"
                                         CaretBrush="{DynamicResource ThemeTextMainBrush}"
                                         SelectionBrush="Gray"
                                         BorderThickness="0,0,0,1"
                                         BorderBrush="{DynamicResource ThemeTextSubBrush}"
                                         FocusAdorner="{x:Null}"
                                         Background="Transparent"/>
                                
                                <Button Command="{Binding ConfirmCustomIpCommand}"
                                        IsEnabled="{Binding UseCustomIp}"
                                        Theme="{StaticResource RobustPlainIconBtn}"
                                        Padding="15,0" Height="36">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Data="M834.1 182.2c-15.1-15.1-39.6-15.1-54.7 0L383.6 578 244.7 439.1c-15.1-15.1-39.6-15.1-54.7 0-15.1 15.1-15.1 39.6 0 54.7l163.6 163.6c15.1 15.1 39.6 15.1 54.7 0l425.8-425.8c15.1-15.1 15.1-39.6-0-54.7z" 
                                                  Width="14" Height="14" Foreground="{DynamicResource SvgIconBrush}"/>
                                        <TextBlock Text="确认生效" VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- 以后在这里填充更多高级设置内容 -->
                    <TextBlock Text="更多高级功能即将推出..." 
                               FontSize="14" Opacity="0.4"
                               Foreground="{DynamicResource ThemeTextMainBrush}"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Panel>
</UserControl>
