<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MdModManager.Views.AlbumCollectionIntroDialog"
        Title="整合包提示"
        Width="760"
        Height="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">

    <Window.Styles>
        <Style Selector="Button.LinkBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FF69B4"/>
        </Style>
        <Style Selector="Button.LinkBtn:pointerover">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        <Style Selector="Button.LinkBtn:pressed">
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="24">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <!-- Header -->
                <TextBlock Text="请仔细阅读该文本，避免不必要的问题发生！！！！"
                           FontSize="22"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Foreground="Red"/>

                <!-- Recommendations -->
                <TextBlock Text="请选择高速DNS获得最佳的下载体验；如果kkgithub可用，也许它的速度会超过高速DNS，但它经常断线。"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="#E0E0E0"/>

                <TextBlock Text="suzimo线路永不断线（特殊极端情况除外），但速度可能会稍慢。"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="#E0E0E0"/>

                <TextBlock Text="高速DNS与suzimo线路每天都有日限额下载，如果你不幸遇到了限额的情况，请切换kkgithub或github线路。"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="#E0E0E0"/>

                <TextBlock Text="#高速DNS也许会在流量高峰时期断线，如遇此情况请在设置中切换到别的下载源再切换回高速DNS。如果你有更好的IP节点，比如通过测速软件得到的最快节点，可以进入设置点击齿轮手动设定节点"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap"
                           Foreground="#E0E0E0"/>

                <!-- Author Note -->
                <TextBlock Text="（作者只是一个穷学生，能力有限QAQ）"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="#FF69B4"/>

                <Border Height="1" Background="#33FFFFFF" Margin="0,4,0,4"/>

                <!-- Credits Paragraph -->
                <WrapPanel ItemSpacing="0" LineSpacing="6">
                    <TextBlock Text="本页谱面全部由" FontSize="14" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    <Button Classes="LinkBtn" Click="OnOpenGreenHubClick" Content="GreenHub" FontSize="14"/>
                    <TextBlock Text="和" FontSize="14" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    <Button Classes="LinkBtn" Click="OnOpenMayflycmdClick" Content="Mayflycmd" FontSize="14"/>
                    <TextBlock Text="整理。其实" FontSize="14" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    <Button Classes="LinkBtn" Click="OnOpenSuZimoClick" Content="我叫苏子沫" FontSize="14"/>
                    <TextBlock Text="与" FontSize="14" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    <Button Classes="LinkBtn" Click="OnOpenGreenHubClick" Content="GreenHub" FontSize="14"/>
                    <TextBlock Text="搬运。" FontSize="14" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,18,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="不再显示该弹窗"
                           FontSize="13"
                           Foreground="Gray"
                           VerticalAlignment="Center"/>
                <CheckBox x:Name="DontShowAgainCheckBox"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="确定"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    Background="#FF00FF"
                    Foreground="White"
                    Click="OnConfirmClick"/>
        </Grid>
    </Grid>
</Window>
