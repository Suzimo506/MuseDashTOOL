<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:models="using:MdModManager.Models"
             xmlns:controls="using:MdModManager.Views.Controls"
             xmlns:helpers="using:MdModManager.Helpers"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:animated="clr-namespace:AnimatedImage.Avalonia;assembly=AnimatedImage.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MdModManager.Views.ChartManagerView"
             x:DataType="vm:ChartManagerViewModel"
             DragDrop.AllowDrop="True">

    <UserControl.Resources>
        <ControlTheme x:Key="PagingIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="RenderTransform" Value="scale(0.92)"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
            <Style Selector="^:disabled /template/ Border#RootBorder">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.45"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- 卡片悬浮效果 -->
        <Style Selector="Border.ChartCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardHoverBgBrush}"/>
        </Style>

        <!-- 无背景图标按钮 -->
        <Style Selector="Button.IconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.IconBtn:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.IconBtn:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button.IconBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.IconBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" PointerPressed="OnBackgroundPointerPressed" Background="Transparent">

        <!-- 顶部标题行 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="谱面管理" FontSize="22" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#FF00FF" Offset="0"/>
                            <GradientStop Color="#FF69B4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}"/>
            </StackPanel>

            <!-- 顶部操作按钮 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- 搜索框 -->
                <TextBox Text="{Binding SearchText}"
                         Classes="ExpandableSearch"
                         Classes.HasText="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Margin="0,0,10,0"
                         MinWidth="0"
                         ContextFlyout="{x:Null}">
                    <!-- 根据展开状态动态设置 Watermark -->
                    <TextBox.Styles>
                        <!-- 默认无水印 / 展开时的宽度与平滑过渡 -->
                        <Style Selector="TextBox.ExpandableSearch">
                            <Setter Property="Width" Value="280" />
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Width" Duration="0:0:0.3" Easing="CubicEaseOut" />
                                </Transitions>
                            </Setter>
                        </Style>
                        <!-- 展开时（获得焦点，或有内容时）才显示水印，避免缩放时文字被挤压 -->
                        <Style Selector="TextBox.ExpandableSearch:focus, TextBox.ExpandableSearch.HasText">
                            <Setter Property="Watermark" Value="搜索谱面名称或作者..." />
                        </Style>
                        <!-- 收起状态（未获取焦点且搜索框无文本时） -->
                        <Style Selector="TextBox.ExpandableSearch:not(:focus):not(.HasText)">
                            <Setter Property="Width" Value="32" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Watermark" Value="" />
                        </Style>
                        <!-- 隐藏原生 TextBox Hover 状态的边框与背景，保持极简 SVG 风格 -->
                        <Style Selector="TextBox.ExpandableSearch:not(:focus):not(.HasText):pointerover /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </TextBox.Styles>
                    <TextBox.InnerRightContent>
                        <Border Background="Transparent" 
                                PointerPressed="OnSearchIconPointerPressed" 
                                Cursor="Hand" 
                                ToolTip.Tip="右键清空，左键可展开" 
                                VerticalAlignment="Center" 
                                Padding="8">
                            <PathIcon Data="M415.59889935 818.40673751c-103.69194019 0-207.38388041-39.48836529-286.31642412-118.42090898-157.86508737-157.87981634-157.86508737-414.78248979 0-572.66230613 157.85035841-157.85035841 414.76776082-157.90927428 572.64757719 0 157.86508737 157.87981634 157.86508737 414.78248979 0 572.66230613-78.93254368 78.93254368-182.63921287 118.42090898-286.33115307 118.42090898z m0-725.22496474c-82.09927197 0-164.21327292 31.25487175-226.70828746 93.74988629-125.00475803 125.00475803-125.00475803 328.44127481 0 453.44603281 125.01948701 124.9753001 328.41181686 125.03421596 453.43130386 0 125.00475803-125.00475803 125.00475803-328.44127481 0-453.44603281-62.5097435-62.49501453-144.60901547-93.74988627-226.7230164-93.74988629z M973.48804978 1013.69813456c-10.78160515 0-21.57793927-4.10938229-29.79670383-12.34287584L658.31757585 715.95203069c-16.46698708-16.46698708-16.46698708-43.14114955 0-59.60813666s43.14114955-16.46698708 59.60813665 0l285.37377009 285.38849908c16.46698708 16.46698708 16.46698708 43.14114955 0 59.60813663a42.07329932 42.07329932 0 0 1-29.81143281 12.35760482z"
                                        Width="16" Height="16" Foreground="{DynamicResource SvgIconBrush}"/>
                        </Border>
                    </TextBox.InnerRightContent>
                </TextBox>
                <!-- 导入按钮 -->
                <Button Classes="IconBtn"
                        Click="OnImportClick"
                        ToolTip.Tip="导入谱面 (将 mdm 复制到 Custom_Albums)">
                    <PathIcon Data="M563.2 42.666667v640c0 23.466667-19.2 42.666667-42.666667 42.666666s-42.666667-19.2-42.666666-42.666666V42.666667c0-23.466667 19.2-42.666667 42.666666-42.666667s42.666667 19.2 42.666667 42.666667 M806.1952 457.275733L550.5792 712.900267a42.7776 42.7776 0 0 1-60.330667 0c-16.597333-16.605867-16.597333-43.776 0-60.330667l255.616-255.624533a42.7776 42.7776 0 0 1 60.330667 0 42.7776 42.7776 0 0 1 0 60.330666 M490.350933 712.8832L234.734933 457.275733a42.7776 42.7776 0 0 1 0-60.330666c16.597333-16.605867 43.776-16.605867 60.330667 0l255.616 255.616a42.7776 42.7776 0 0 1 0 60.330666 42.7776 42.7776 0 0 1-60.330667 0 M904.533333 1024H136.533333c-70.570667 0-128-57.429333-128-128V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666667 42.666667v256c0 23.552 19.114667 42.666667 42.666666 42.666667h768c23.552 0 42.666667-19.114667 42.666667-42.666667V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666666 42.666667v256c0 70.570667-57.429333 128-128 128"
                               Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/>
                </Button>
                
                <!-- 打开文件夹按钮 -->
                <Button Classes="IconBtn"
                        Command="{Binding OpenFolderCommand}"
                        ToolTip.Tip="打开谱面文件夹">
                    <PathIcon Data="M928 352v-48c0-35.3-28.7-64-64-64H485.2c-21 0-40.7-10.3-52.6-27.6l-61.5-88.9c-12-17.3-31.6-27.6-52.6-27.6H64c-35.3 0-64 28.7-64 64v656c0 70.7 57.3 128 128 128h638c57.8 0 108.5-38.8 123.6-94.6L928 707.2l74.2-274.5c11-40.7-19.6-80.7-61.8-80.7H928zM80 160h230.1c5.3 0 10.2 2.6 13.2 6.9l50.6 73.1H80c-8.8 0-16-7.2-16-16v-48c0-8.8 7.2-16 16-16z m0 144h768c8.8 0 16 7.2 16 16v32H209c-28.9 0-54.2 19.4-61.8 47.3L79.7 649c-2.4 9-15.7 7.3-15.7-2.1V320c0-8.8 7.2-16 16-16z m784 394.7l-36.2 134c-7.5 27.9-32.9 47.3-61.8 47.3H125.4c-21.1 0-36.4-20-30.9-40.3l111.3-411.8c1.9-7 8.2-11.8 15.4-11.8h698.3c10.5 0 18.2 10 15.4 20.2l-7 25.7L864 698.7z" 
                               Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/>
                </Button>

                <!-- 刷新按钮 -->
                <Button Classes="IconBtn"
                        Command="{Binding RefreshCommand}"
                        ToolTip.Tip="刷新谱面列表">
                    <PathIcon Data="M369.777778 160.568889a42.666667 42.666667 0 0 1-42.666667 42.666667H128a42.666667 42.666667 0 1 1 0-85.333334h199.111111a42.666667 42.666667 0 0 1 42.666667 42.666667 M327.111111 402.346667a42.666667 42.666667 0 0 1-42.666667-42.666667v-199.111111a42.666667 42.666667 0 1 1 85.333334 0v199.111111a42.666667 42.666667 0 0 1-42.666667 42.666667 M512.014222 938.652444h-0.753778a424.533333 424.533333 0 0 1-294.272-124.913777c-80.583111-80.583111-124.956444-187.733333-124.956444-301.696 0-113.976889 44.373333-221.112889 124.970667-301.696l73.088-73.116445a42.680889 42.680889 0 0 1 60.359111 60.344889l-73.102222 73.102222a339.057778 339.057778 0 0 0-99.982223 241.351111A339.128889 339.128889 0 0 0 277.333333 753.422222a339.640889 339.640889 0 0 0 235.406223 99.911111 42.680889 42.680889 0 0 1-0.725334 85.333334 M654.222222 863.473778v-0.014222a42.666667 42.666667 0 0 1 42.666667-42.666667h199.111111a42.666667 42.666667 0 0 1 0 85.333333H696.888889a42.666667 42.666667 0 0 1-42.666667-42.666666 M696.888889 621.681778a42.666667 42.666667 0 0 1 42.666667 42.666666v199.111112a42.666667 42.666667 0 0 1-85.333334 0v-199.111112a42.666667 42.666667 0 0 1 42.666667-42.666666 M703.715556 899.285333a42.638222 42.638222 0 0 1-30.165334-72.832l73.130667-73.102222c133.077333-133.091556 133.077333-349.653333 0-482.730667A339.100444 339.100444 0 0 0 505.315556 170.666667a42.666667 42.666667 0 1 1 0-85.333334c113.976889 0 221.112889 44.387556 301.681777 124.970667 166.357333 166.343111 166.357333 437.048889 0 603.377778l-73.102222 73.116444a42.524444 42.524444 0 0 1-30.165333 12.515556"
                               Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 工具栏：顶部分页栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Border HorizontalAlignment="Center"
                    Background="Transparent"
                    Padding="8,4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding LoadFirstPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="第一页">
                        <PathIcon Data="M321.53 929m-41.47 0l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47Z M787.26 170L411.44 514.25l375.82 344.21a39.32 39.32 0 0 1 13.11 29c0 36.51-48.2 54.79-76.38 29L348.17 572.2c-34.95-32-34.95-83.9 0-115.9L724 112.08c28.18-25.81 76.38-7.53 76.38 29A39.33 39.33 0 0 1 787.26 170z" Foreground="{DynamicResource SvgIconBrush}" Width="14" Height="14"/>
                    </Button>
                    <Button Command="{Binding LoadPrevPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="上一页">
                        <PathIcon Data="M704 944c-10.88 0-22.4-3.84-31.36-11.52l-448-384c-10.88-8.96-16.64-22.4-16.64-36.48s6.4-27.52 16.64-36.48l448-384c19.84-17.28 50.56-14.72 67.84 5.12s14.72 50.56-5.12 67.84L329.6 512l405.76 347.52c19.84 17.28 22.4 47.36 5.12 67.84-9.6 10.88-23.04 16.64-36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="第" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <Panel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPage}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="ExtraBold" FontSize="12" Cursor="Hand" PointerPressed="OnPageNumberClick" IsVisible="{Binding !IsEditingPageNumber}"/>
                            <TextBox Name="PageJumpTextBox_Top" Text="{Binding JumpPageText}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="12" Width="42" Height="22" Padding="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" CornerRadius="4" LostFocus="OnPageJumpLostFocus" IsVisible="{Binding IsEditingPageNumber}" Background="{DynamicResource ControlBgBrush}">
                                <TextBox.KeyBindings>
                                    <KeyBinding Command="{Binding JumpPageCommand}" Gesture="Enter"/>
                                    <KeyBinding Command="{Binding CancelEditPageCommand}" Gesture="Escape"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                        </Panel>
                        <TextBlock Text="/" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock Text="{Binding TotalPages}" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock Text="页" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                    <Button Command="{Binding LoadNextPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="下一页">
                        <PathIcon Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding LoadLastPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="最末页">
                        <PathIcon Data="M706.19 106m41.47 0l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47Z M240.46 865l375.81-344.25-375.81-344.21a39.32 39.32 0 0 1-13.11-29c0-36.51 48.2-54.79 76.38-29L679.55 462.8c35 32 35 83.9 0 115.9L303.73 922.92c-28.18 25.81-76.38 7.53-76.38-29A39.33 39.33 0 0 1 240.46 865z" Foreground="{DynamicResource SvgIconBrush}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 主体 -->
        <Grid Grid.Row="2">
            <StackPanel IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="正在加载…" FontSize="18" Foreground="#888888" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 缺少 Custom_Albums 文件夹提示 -->
            <StackPanel IsVisible="{Binding IsCustomAlbumsMissing}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                <TextBlock Text="请先创建Custom_Albums文件夹" FontSize="18" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 文件夹存在但没有谱面时的正常空状态提示 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsEmpty"/>
                        <Binding Path="!IsCustomAlbumsMissing"/>
                    </MultiBinding>
                </StackPanel.IsVisible>
                <TextBlock Text="🎵" FontSize="60" HorizontalAlignment="Center" Foreground="Gray"/>
                <TextBlock Text="Custom_Albums 中没有找到谱面" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="请将 .mdm 文件放入游戏目录下的 Custom_Albums 文件夹" FontSize="13" Foreground="#555555" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding HasNoSearchResults}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="15">
                <TextBlock Text="没有找到符合条件的谱面" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="试试别的关键词，或清空搜索后查看全部谱面" FontSize="13" Foreground="#666666" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 谱面卡片网格 -->
            <ScrollViewer x:Name="ChartScrollViewer"
                          IsVisible="{Binding HasVisibleCharts}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Grid RowDefinitions="*,Auto">
                    <ItemsControl ItemsSource="{Binding Charts}" Grid.Row="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ChartInfo">
                                <Border Classes="ChartCard"
                                        Background="{DynamicResource CardBgBrush}"
                                        CornerRadius="10"
                                        Width="208"
                                        Margin="2,0,2,16"
                                        VerticalAlignment="Top"
                                        ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">

                                        <!-- 封面图 -->
                                        <Border Grid.Row="0" Height="170" ClipToBounds="True" CornerRadius="10,10,0,0">
                                            <Panel>
                                                <!-- 有封面时显示 -->
                                                <Image IsVisible="{Binding HasAnimatedCoverSource}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       animated:ImageBehavior.AnimatedSource="{Binding AnimatedCoverSource}"/>
                                                <Image Source="{Binding CoverImage}"
                                                       IsVisible="{Binding HasCoverBitmap}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                                <!-- 无封面占位 -->
                                                <Border IsVisible="{Binding !HasAnyCover}"
                                                        Background="#333333"
                                                        CornerRadius="10,10,0,0">
                                                    <TextBlock Text="🎵" FontSize="56"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="#555555"/>
                                                </Border>

                                                <!-- 正在播放叠加 -->
                                                <Border IsVisible="{Binding IsPlaying}"
                                                        Background="#80000000"
                                                        CornerRadius="10,10,0,0">
                                                    <TextBlock Text="▶ 试听中" FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- New 标签叠加 -->
                                                <Border IsVisible="{Binding IsNewDownload}" 
                                                        Background="#FF4444" CornerRadius="4" Padding="6,2" Margin="6,0,0,6" 
                                                        HorizontalAlignment="Left" VerticalAlignment="Bottom">
                                                    <TextBlock Text="New" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Panel>
                                        </Border>

                                        <!-- 下方信息区 -->
                                        <StackPanel Grid.Row="1" Margin="12,10,12,10" Spacing="5">

                                            <!-- 歌曲名称 (带滚动动画) -->
                                            <controls:MarqueeText Text="{Binding Name}"
                                                                  HighlightText="{Binding Name}"
                                                                  SearchText="{Binding $parent[UserControl].((vm:ChartManagerViewModel)DataContext).SearchText}"
                                                                  FontSize="14" FontWeight="Bold"
                                                                  Foreground="{DynamicResource ThemeTextMainBrush}"
                                                                  Height="20"
                                                                  IsScrollingEnabled="{Binding $parent[UserControl].((vm:ChartManagerViewModel)DataContext).EnableMarquee}"
                                                                  ToolTip.Tip="{Binding Name}"/>

                                            <!-- 作曲 / 谱师 -->
                                            <TextBlock Text="{Binding SubInfo}"
                                                       helpers:TextBlockHelper.HighlightText="{Binding SubInfo}"
                                                       helpers:TextBlockHelper.SearchText="{Binding $parent[UserControl].((vm:ChartManagerViewModel)DataContext).SearchText}"
                                                       IsVisible="{Binding SubInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextSubBrush}"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding SubInfo}"/>

                                            <!-- BPM和难度同行显示 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Spacing="8" MinHeight="16">
                                                <TextBlock
                                                    IsVisible="{Binding Bpm, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Text="{Binding Bpm, StringFormat='BPM: \{0\}'}"
                                                    FontSize="11" Foreground="{DynamicResource ThemeTextTertiaryBrush}"
                                                    VerticalAlignment="Center"/>
                                                <ItemsControl ItemsSource="{Binding Difficulties}" VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#331a3a1a" CornerRadius="3" Padding="4,1">
                                                                <TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource SvgIconBrush}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- 操作按钮行 -->
                                            <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                                <!-- 试听按钮 -->
                                                <Button Grid.Column="0"
                                                        Classes="IconBtn"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].((vm:ChartManagerViewModel)DataContext).TogglePreviewCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Panel>
                                                        <PathIcon Data="M896 512L128 1024V0z"
                                                                  Foreground="{DynamicResource SvgIconBrush}" Width="22" Height="22"
                                                                  IsVisible="{Binding !IsPlaying}"/>
                                                        <PathIcon Data="M722.9375 933.875H301.0625a210.9375 210.9375 0 0 1-210.9375-210.9375V301.0625a210.9375 210.9375 0 0 1 210.9375-210.9375h421.875a210.9375 210.9375 0 0 1 210.9375 210.9375v421.875a210.9375 210.9375 0 0 1-210.9375 210.9375z"
                                                                  Foreground="{DynamicResource SvgIconBrush}" Width="22" Height="22"
                                                                  IsVisible="{Binding IsPlaying}"/>
                                                    </Panel>
                                                </Button>

                                                <!-- 卸载按钮 -->
                                                <Button Grid.Column="1"
                                                        Classes="IconBtn"
                                                        HorizontalAlignment="Center"
                                                        Click="OnDeleteChartClick"
                                                        Tag="{Binding}">
                                                    <PathIcon Data="M981.465503 192.054069v42.678682a20.185863 20.185863 0 0 1-6.055759 15.283582 20.474233 20.474233 0 0 1-15.283582 6.055759H896.108139v630.952408a152.259082 152.259082 0 0 1-31.143904 95.738665 92.85497 92.85497 0 0 1-75.264432 40.371727H234.300197a93.720079 93.720079 0 0 1-75.264432-38.929879 145.914954 145.914954 0 0 1-31.143904-94.296818v-634.412842H63.873838a19.897494 19.897494 0 0 1-15.283582-6.055759 20.474233 20.474233 0 0 1-6.055759-15.283582V192.342439a20.185863 20.185863 0 0 1 6.055759-15.283582 20.474233 20.474233 0 0 1 15.283582-6.055759h206.184174l46.715855-111.310617A94.008448 94.008448 0 0 1 352.820051 17.590538a94.873557 94.873557 0 0 1 52.771613-17.302169h213.393411a94.008448 94.008448 0 0 1 52.771613 17.302169 91.989862 91.989862 0 0 1 36.046184 42.101943l46.715855 111.310617h205.895804a20.185863 20.185863 0 0 1 15.283582 6.055759 20.762602 20.762602 0 0 1 5.47902 14.995212z m-597.501549 640.180231V362.768798a20.185863 20.185863 0 0 0-6.055759-15.283583 20.474233 20.474233 0 0 0-15.283582-6.055759H319.945931a20.185863 20.185863 0 0 0-15.283582 6.055759 20.474233 20.474233 0 0 0-6.055759 15.283583v469.465502a20.185863 20.185863 0 0 0 6.055759 15.283582 20.474233 20.474233 0 0 0 15.283582 6.055759h42.678682a20.474233 20.474233 0 0 0 21.339341-21.339341zM362.624613 170.714728h298.750774l-32.009011-77.859758a18.167277 18.167277 0 0 0-11.534779-7.209236h-211.086455a18.744016 18.744016 0 0 0-11.534779 7.209236z m192.054069 661.519572V362.768798a20.185863 20.185863 0 0 0-6.055759-15.283583 20.474233 20.474233 0 0 0-15.283582-6.055759h-42.678682a20.185863 20.185863 0 0 0-15.283582 6.055759 20.474233 20.474233 0 0 0-6.055759 15.283583v469.465502a20.185863 20.185863 0 0 0 6.055759 15.283582 20.474233 20.474233 0 0 0 15.283582 6.055759h42.678682a20.185863 20.185863 0 0 0 15.283582-6.055759 20.762602 20.762602 0 0 0 6.055759-15.283582z m170.714728 0V362.768798a20.185863 20.185863 0 0 0-6.055759-15.283583 20.474233 20.474233 0 0 0-15.283582-6.055759h-42.678682a20.185863 20.185863 0 0 0-15.283582 6.055759 20.474233 20.474233 0 0 0-6.055759 15.283583v469.465502a20.185863 20.185863 0 0 0 6.055759 15.283582 20.474233 20.474233 0 0 0 15.283582 6.055759h42.678682a20.474233 20.474233 0 0 0 21.339341-21.339341z m0 0"
                                                               Foreground="{DynamicResource SvgIconBrush}" Width="22" Height="22"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="1" Background="Transparent" Margin="10,20,10,30" Padding="15,8" CornerRadius="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                            <Button Command="{Binding LoadFirstPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="第一页">
                                <PathIcon Data="M321.53 929m-41.47 0l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47Z M787.26 170L411.44 514.25l375.82 344.21a39.32 39.32 0 0 1 13.11 29c0 36.51-48.2 54.79-76.38 29L348.17 572.2c-34.95-32-34.95-83.9 0-115.9L724 112.08c28.18-25.81 76.38-7.53 76.38 29A39.33 39.33 0 0 1 787.26 170z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                            </Button>
                            <Button Command="{Binding LoadPrevPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="上一页">
                                <PathIcon Data="M704 944c-10.88 0-22.4-3.84-31.36-11.52l-448-384c-10.88-8.96-16.64-22.4-16.64-36.48s6.4-27.52 16.64-36.48l448-384c19.84-17.28 50.56-14.72 67.84 5.12s14.72 50.56-5.12 67.84L329.6 512l405.76 347.52c19.84 17.28 22.4 47.36 5.12 67.84-9.6 10.88-23.04 16.64-36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/>
                            </Button>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="第" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/>
                                <Panel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentPage}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="14" Cursor="Hand" PointerPressed="OnPageNumberClick" IsVisible="{Binding !IsEditingPageNumber}"/>
                                    <TextBox Name="PageJumpTextBox_Bottom" Text="{Binding JumpPageText}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="14" Width="50" Height="28" Padding="4,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" CornerRadius="4" LostFocus="OnPageJumpLostFocus" IsVisible="{Binding IsEditingPageNumber}" Background="{DynamicResource ControlBgBrush}">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Command="{Binding JumpPageCommand}" Gesture="Enter"/>
                                            <KeyBinding Command="{Binding CancelEditPageCommand}" Gesture="Escape"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                </Panel>
                                <TextBlock Text="/" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Text="{Binding TotalPages}" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Text="页" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                            <Button Command="{Binding LoadNextPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="下一页">
                                <PathIcon Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88-23.04 16.64-36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/>
                            </Button>
                            <Button Command="{Binding LoadLastPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource PagingIconBtn}" ToolTip.Tip="最末页">
                                <PathIcon Data="M706.19 106m41.47 0l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47Z M240.46 865l375.81-344.25-375.81-344.21a39.32 39.32 0 0 1-13.11-29c0-36.51 48.2-54.79 76.38-29L679.55 462.8c35 32 35 83.9 0 115.9L303.73 922.92c-28.18 25.81-76.38 7.53-76.38-29A39.33 39.33 0 0 1 240.46 865z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
