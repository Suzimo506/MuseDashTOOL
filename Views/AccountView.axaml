<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:models="using:MdModManager.Models"
             xmlns:conv="using:MdModManager.Converters"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="MdModManager.Views.AccountView"
             x:DataType="vm:AccountViewModel">

    <UserControl.Resources>
        <conv:AccuracyColorConverter x:Key="AccuracyColorConverter"/>
        <ControlTheme x:Key="AccountIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Root"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Root">
                <Setter Property="Opacity" Value="0.78"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#Root">
                <Setter Property="Opacity" Value="0.58"/>
            </Style>
        </ControlTheme>

        <!-- 工具栏小按钮主题：强力隔离方案，彻底解决灰色背景 -->
        <ControlTheme x:Key="ToolbarSmallBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSubBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Root"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            RenderTransform="none">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.75"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#Root">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="RenderTransform" Value="scale(0.95)"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.ProfileBand">
            <Setter Property="Background" Value="{DynamicResource ModCardBgBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="22,18"/>
        </Style>

        <Style Selector="Border.RecordRow">
            <Setter Property="Background" Value="#12000000"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 搜索匹配高亮样式 -->
        <Style Selector="Border.RecordRow.SearchMatch">
            <Setter Property="Background" Value="#45FF69B4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="24">
        <!-- 个人信息 -->
        <Border Grid.Row="0" Classes="ProfileBand" Margin="0,0,0,18">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" RowDefinitions="Auto">
                <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center" Margin="0,0,30,0">
                    <TextBlock Text="{Binding Nickname}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextMainBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#22000000" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ThemeTextSubBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="6"
                            Width="110"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="上榜歌曲" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding RecordsCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Right"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="6"
                            Width="90"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="金S数" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding PerfectsCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Right"/>
                </StackPanel>

                <Grid Grid.Column="3" RowDefinitions="Auto,Auto" ColumnDefinitions="92,Auto" Margin="26,0,18,0" VerticalAlignment="Center" RowSpacing="8" ColumnSpacing="14">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="定级" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RelativeLevel}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="平均准确率" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AverageAccuracy}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Button Grid.Column="4"
                        Theme="{StaticResource AccountIconBtn}"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,-8,0"
                        ToolTip.Tip="刷新账号数据">
                    <PathIcon Data="M874.666667 512a362.666667 362.666667 0 0 1-623.36 252.16l-72.533334 72.533333A465.066667 465.066667 0 0 0 977.066667 512h-102.4zM149.333333 512a362.666667 362.666667 0 0 1 623.36-252.16l-92.16 92.16H938.666667V93.866667l-93.44 93.44A465.066667 465.066667 0 0 0 46.933333 512h102.4z"
                              Width="22"
                              Height="22"
                              Foreground="{DynamicResource SvgIconBrush}"/>
                </Button>

            </Grid>
        </Border>

        <!-- 工具栏：排序 + 搜索 -->
        <Border Grid.Row="1"
                Background="{DynamicResource ModCardBgBrush}"
                CornerRadius="8"
                Padding="12,8"
                Margin="0,0,0,14"
                IsVisible="{Binding !IsLoading}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左侧：排序按钮 -->
                <Button Grid.Column="0"
                        Theme="{StaticResource ToolbarSmallBtn}"
                        Command="{Binding CycleSortModeCommand}"
                        ToolTip.Tip="点击切换排序方式：默认 → 排名最高 → 准确率最高 → 最难">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"
                                  Width="14"
                                  Height="14"
                                  Foreground="{DynamicResource SvgIconBrush}"/>
                        <TextBlock Text="{Binding SortLabel}"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeTextSubBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 右侧：搜索区域 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <!-- 上一项 -->
                    <Button Theme="{StaticResource ToolbarSmallBtn}"
                            Command="{Binding SearchPrevCommand}"
                            Padding="6,6"
                            ToolTip.Tip="上一项">
                        <PathIcon Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"
                                  Width="14"
                                  Height="14"
                                  Foreground="{DynamicResource SvgIconBrush}"/>
                    </Button>

                    <!-- 搜索状态 -->
                    <TextBlock Text="{Binding SearchStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeTextSubBrush}"
                               VerticalAlignment="Center"
                               MinWidth="36"
                               TextAlignment="Center"/>

                    <!-- 下一项 -->
                    <Button Theme="{StaticResource ToolbarSmallBtn}"
                            Command="{Binding SearchNextCommand}"
                            Padding="6,6"
                            ToolTip.Tip="下一项">
                        <PathIcon Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"
                                  Width="14"
                                  Height="14"
                                  Foreground="{DynamicResource SvgIconBrush}"/>
                    </Button>

                    <!-- 搜索框 -->
                    <Border Background="Transparent" CornerRadius="6" Padding="8,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     x:Name="SearchBox"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="搜索歌曲..."
                                     FontSize="12"
                                     MinWidth="140"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,6"
                                     Foreground="{DynamicResource ThemeTextMainBrush}"
                                     KeyDown="OnSearchBoxKeyDown"/>
                            <Button Grid.Column="1"
                                    Theme="{StaticResource ToolbarSmallBtn}"
                                    Command="{Binding SearchConfirmCommand}"
                                    Padding="4,4"
                                    ToolTip.Tip="搜索">
                                <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                          Width="14"
                                          Height="14"
                                          Foreground="{DynamicResource SvgIconBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 加载态 -->
        <Border Grid.Row="2" IsVisible="{Binding IsLoading}" Background="Transparent">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                <ProgressBar IsIndeterminate="True"
                             Width="220"
                             Height="3"
                             Foreground="{DynamicResource SvgIconBrush}"
                             Background="#333333"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ThemeTextSubBrush}"
                           HorizontalAlignment="Center"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- 成绩列表 -->
        <ScrollViewer Grid.Row="2"
                      x:Name="RecordScroller"
                      IsVisible="{Binding !IsLoading}"
                      ScrollChanged="OnScrollChanged">
            <StackPanel Spacing="10">
                <ItemsControl ItemsSource="{Binding RecentPlays}" x:Name="RecordsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PlayerSongRecord">
                            <Border Classes="RecordRow"
                                    Classes.SearchMatch="{Binding IsSearchMatch}">
                                <Grid ColumnDefinitions="32,Auto,*,150" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayIndex}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SvgIconBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="1"
                                            Width="56"
                                            Height="56"
                                            CornerRadius="28"
                                            Margin="0,0,14,0"
                                            ClipToBounds="True"
                                            Background="Transparent">
                                        <Panel>
                                            <asyncImageLoader:AdvancedImage Source="{Binding CoverUrl}"
                                                                           Stretch="UniformToFill"
                                                                           IsVisible="{Binding HasCoverUrl}"/>
                                            <PathIcon Data="M512 128v533.333333a128 128 0 1 0 85.333333 120.533334V298.666667h213.333334V128H512z"
                                                      Foreground="#40FFFFFF"
                                                      Width="28"
                                                      Height="28"
                                                      IsVisible="{Binding !HasCoverUrl}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Panel>
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="5" VerticalAlignment="Center" Margin="0,0,18,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextMainBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Author}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource ThemeTextSubBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Background="#22FF6699" CornerRadius="3" Padding="5,1">
                                                <TextBlock Text="{Binding Level}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SvgIconBrush}"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <PathIcon Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"
                                                          Width="13"
                                                          Height="13"
                                                          Foreground="{DynamicResource ThemeTextSubBrush}"/>
                                                <TextBlock Text="{Binding Rank}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSubBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Spacing="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Accuracy}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Accuracy, Converter={StaticResource AccuracyColorConverter}}"
                                                   TextAlignment="Right"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding Score}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource ThemeTextSubBrush}"
                                                   TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
