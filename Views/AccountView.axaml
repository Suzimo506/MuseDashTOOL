<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="MdModManager.Views.AccountView"
             x:DataType="vm:AccountViewModel">

    <!-- Match musedash.moe dark theme perfectly -->
    <UserControl.Styles>
        <Style Selector="Border.HeaderCard">
            <Setter Property="Background" Value="{DynamicResource ModCardBgBrush}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Styles>

    <!-- Main Container: Dark gradient background matching the site glow -->
    <Border Background="Transparent">
        <Grid RowDefinitions="Auto,*">

            <!-- Top Header containing Username & Relative Level -->
            <Border Grid.Row="0" Margin="32,32,32,0" Classes="HeaderCard" Padding="32,48">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    
                    <!-- Left: Names -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Nickname}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Uid}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="18"/>
                    </StackPanel>
                    
                    <!-- Middle: Relative Level -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RelativeLevel}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="→ 定级" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Right: Status / Refresh -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding StatusMessage}" 
                                   Foreground="{DynamicResource ThemeTextSubBrush}" 
                                   FontSize="14" 
                                   TextWrapping="Wrap"
                                   MaxWidth="200"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Loading overlay -->
            <Border Grid.Row="1" IsVisible="{Binding IsLoading}" Background="Transparent" ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressBar IsIndeterminate="True" Width="200" Foreground="#3290b0" Background="#333333" Height="2" CornerRadius="1"/>
                    <TextBlock Text="Loading player data..." Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Content Area (Scrollable) -->
            <ScrollViewer Grid.Row="1" IsVisible="{Binding !IsLoading}" ScrollChanged="OnScrollChanged">
                <StackPanel Margin="32,0,32,32">
                    
                    <!-- Stat Row -->
                    <Grid ColumnDefinitions="*,*,*" Margin="0,24,0,48">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="上榜歌曲" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RecordsCount}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="金S数" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding PerfectsCount}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="平均准确率" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding AverageAccuracy}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chart Placeholder (We could draw a real chart later, but keeping it empty/subtle for now) -->
                    <Border Height="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="0,0,0,32"/>

                    <!-- Songs List -->
                    <ItemsControl ItemsSource="{Binding RecentPlays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,0,32" VerticalAlignment="Center">
                                    
                                    <!-- Cover Art: actual webp from musedash.moe -->
                                    <Border Grid.Column="0" Width="100" Height="100" CornerRadius="50" Margin="0,0,24,0" ClipToBounds="True">
                                        <Panel>
                                            <!-- Fallback gradient background -->
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                        <GradientStop Color="#0f2027" Offset="0"/>
                                                        <GradientStop Color="#2c5364" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- Real cover image via AsyncImageLoader (supports HTTP URLs) -->
                                            <asyncImageLoader:AdvancedImage Source="{Binding CoverUrl}" Stretch="UniformToFill"
                                                   IsVisible="{Binding CoverUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <!-- Musical note shown if no cover -->
                                            <PathIcon Data="M 12 3 v 10.55 c -0.59 -0.34 -1.27 -0.55 -2 -0.55 c -2.21 0 -4 1.79 -4 4 s 1.79 4 4 4 s 4 -1.79 4 -4 V 7 h 4 V 3 h -6 z"
                                                      Foreground="#33ffffff" Width="40" Height="40"
                                                      IsVisible="{Binding CoverUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                        </Panel>
                                    </Border>

                                    <!-- Song Title & Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <WrapPanel VerticalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="26" FontWeight="Bold" Margin="0,0,8,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Level}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding Author}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="15"/>
                                    </StackPanel>

                                    <!-- Acc & Score & Gear -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,32,0" MinWidth="180">
                                        <TextBlock Text="{Binding Accuracy}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="26" FontWeight="Bold" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Score}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="15" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Gear}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="13"/>
                                    </StackPanel>

                                    <!-- Rank -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,0,0,4">
                                            <!-- Desktop icon SVG path -->
                                            <PathIcon Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z" 
                                                      Foreground="{DynamicResource ThemeTextMainBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Rank}" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="26" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
