<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:helpers="using:MdModManager.Helpers"
             xmlns:models="using:MdModManager.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MdModManager.Views.ModManagerView"
             x:DataType="vm:ModManagerViewModel"
             DragDrop.AllowDrop="True">
    <UserControl.Resources>
        <helpers:BoolToAngleConverter x:Key="BoolToAngleConverter"/>
        <helpers:BoolToColorConverter x:Key="BoolToColorConverter"/>

        <!-- 纯图标按钮主题 (无边距、无背景，强隔离) -->
        <ControlTheme x:Key="RobustPlainIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="RenderTransform" Value="scale(0.92)"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.TabBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <!-- Add RenderTransform to allow scaling -->
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.TabBtn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.3)"/>
        </Style>
        <Style Selector="Button.TabBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
        </Style>
        <Style Selector="Button.TabBtn:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
        </Style>
        <Style Selector="Button.TabBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style Selector="Button.ActiveTabBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransform" Value="scale(1.3)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ActiveTabBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
        </Style>
        <Style Selector="Button.ActiveTabBtn:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
        </Style>
        <Style Selector="Button.ActiveTabBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>


    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" PointerPressed="OnBackgroundPointerPressed" Background="Transparent">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                <Button Content="本地" Command="{Binding SelectLocalTabCommand}"
                        Classes.ActiveTabBtn="{Binding IsLocalTabSelected}"
                        Classes.TabBtn="{Binding !IsLocalTabSelected}"/>
                
                <Button Command="{Binding SelectUpdateTabCommand}"
                        Classes.ActiveTabBtn="{Binding IsUpdateTabSelected}"
                        Classes.TabBtn="{Binding !IsUpdateTabSelected}">
                    <Panel>
                        <TextBlock Text="更新" VerticalAlignment="Center"
                                   IsVisible="{Binding ShowUpdateBadge}"
                                   FontWeight="Bold" Foreground="#FF00FF"/>
                        <TextBlock Text="更新" VerticalAlignment="Center"
                                   IsVisible="{Binding !ShowUpdateBadge}"/>
                    </Panel>
                </Button>

                <Button Content="下载" Command="{Binding SelectDownloadTabCommand}"
                        Classes.ActiveTabBtn="{Binding IsDownloadTabSelected}"
                        Classes.TabBtn="{Binding !IsDownloadTabSelected}"/>

                <!-- 不再提醒：仅更新 Tab 时显示，放在下载按钮右侧 -->
                <Button Theme="{StaticResource RobustPlainIconBtn}"
                        IsVisible="{Binding ShowDismissUpdateNoticeButton}"
                        Command="{Binding DismissUpdateNoticeCommand}"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        ToolTip.Tip="不再提醒">
                    <PathIcon Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"
                              Data="M805.651749 170.130286a37.668571 37.668571 0 0 1 32.694857 17.92 430.811429 430.811429 0 0 1 61.732571 212.626285l0.146286 11.483429v282.989714l111.323428 93.915429c25.380571 21.430857 11.190857 61.44-21.138285 64.146286l-3.364572 0.146285H717.36832C693.084891 951.149714 611.311177 1024 512.56832 1024c-98.742857 0-180.443429-72.850286-204.8-170.642286H188.033463a37.083429 37.083429 0 0 1-37.376-34.816 36.864 36.864 0 0 1 33.792-38.180571l3.584-0.146286h698.368l-48.128-40.667428a37.083429 37.083429 0 0 1-12.8-24.137143l-0.219429-3.510857V412.16c0-67.437714-18.066286-131.876571-51.419428-186.806857a35.84 35.84 0 0 1-0.438857-36.571429 37.595429 37.595429 0 0 1 32.256-18.651428z m-166.253715 683.154285l-253.513143 0.073143C406.730606 910.994286 456.24832 950.857143 512.56832 950.857143c56.32 0 105.910857-39.862857 126.756571-97.499429zM837.322606 33.938286c14.774857 13.019429 16.530286 35.108571 4.022857 50.176l-2.633143 2.779428L64.714606 842.605714a38.107429 38.107429 0 0 1-51.785143 1.462857 35.986286 35.986286 0 0 1-3.803429-50.395428l2.56-2.779429L785.756891 35.108571a38.180571 38.180571 0 0 1 51.565715-1.243428zM514.762606 0c58.221714 0 114.688 13.897143 166.034285 40.155429a36.132571 36.132571 0 0 1 15.067429 48.932571 37.888 37.888 0 0 1-49.737143 15.798857A287.451429 287.451429 0 0 0 514.689463 73.142857c-168.228571 0-306.541714 146.724571-310.491429 330.971429l-0.073143 8.045714v140.361143a36.937143 36.937143 0 0 1-35.693714 36.571428 37.156571 37.156571 0 0 1-39.058286-33.060571l-0.146285-3.510857V412.16C129.226606 185.270857 300.892891 0 514.689463 0z"/>
                </Button>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- 搜索框 -->
                <TextBox Text="{Binding SearchText}" 
                         Classes="ExpandableSearch"
                         Classes.HasText="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Margin="0,0,10,0"
                         MinWidth="0"
                         ContextFlyout="{x:Null}">
                    <!-- 根据展开状态动态设置 Watermark -->
                    <TextBox.Styles>
                        <!-- 默认无水印 / 展开时的宽度与平滑过渡 -->
                        <Style Selector="TextBox.ExpandableSearch">
                            <Setter Property="Width" Value="280" />
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Width" Duration="0:0:0.3" Easing="CubicEaseOut" />
                                </Transitions>
                            </Setter>
                        </Style>
                        <!-- 展开时（获得焦点，或有内容时）才显示水印，避免缩放时文字被挤压 -->
                        <Style Selector="TextBox.ExpandableSearch:focus, TextBox.ExpandableSearch.HasText">
                            <Setter Property="Watermark" Value="搜索 Mod 名称或作者..." />
                        </Style>
                        <!-- 收起状态（未获取焦点且搜索框无文本时） -->
                        <Style Selector="TextBox.ExpandableSearch:not(:focus):not(.HasText)">
                            <Setter Property="Width" Value="32" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Watermark" Value="" />
                        </Style>
                        <!-- 隐藏原生 TextBox Hover 状态的边框与背景，保持极简 SVG 风格 -->
                        <Style Selector="TextBox.ExpandableSearch:not(:focus):not(.HasText):pointerover /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </TextBox.Styles>
                    <TextBox.InnerRightContent>
                        <Border Background="Transparent" 
                                PointerPressed="OnSearchIconPointerPressed" 
                                Cursor="Hand" 
                                ToolTip.Tip="右键清空，左键可展开" 
                                VerticalAlignment="Center" 
                                Padding="8">
                            <PathIcon Data="M415.59889935 818.40673751c-103.69194019 0-207.38388041-39.48836529-286.31642412-118.42090898-157.86508737-157.87981634-157.86508737-414.78248979 0-572.66230613 157.85035841-157.85035841 414.76776082-157.90927428 572.64757719 0 157.86508737 157.87981634 157.86508737 414.78248979 0 572.66230613-78.93254368 78.93254368-182.63921287 118.42090898-286.33115307 118.42090898z m0-725.22496474c-82.09927197 0-164.21327292 31.25487175-226.70828746 93.74988629-125.00475803 125.00475803-125.00475803 328.44127481 0 453.44603281 125.01948701 124.9753001 328.41181686 125.03421596 453.43130386 0 125.00475803-125.00475803 125.00475803-328.44127481 0-453.44603281-62.5097435-62.49501453-144.60901547-93.74988627-226.7230164-93.74988629z M973.48804978 1013.69813456c-10.78160515 0-21.57793927-4.10938229-29.79670383-12.34287584L658.31757585 715.95203069c-16.46698708-16.46698708-16.46698708-43.14114955 0-59.60813666s43.14114955-16.46698708 59.60813665 0l285.37377009 285.38849908c16.46698708 16.46698708 16.46698708 43.14114955 0 59.60813663a42.07329932 42.07329932 0 0 1-29.81143281 12.35760482z"
                                      Width="16" Height="16" Foreground="{DynamicResource SvgIconBrush}"/>
                        </Border>
                    </TextBox.InnerRightContent>
                </TextBox>
                
                <Button Theme="{StaticResource RobustPlainIconBtn}"
                        Click="OnImportClick"
                        ToolTip.Tip="导入 Mod (.dll / .zip)">
                    <PathIcon Data="M563.2 42.666667v640c0 23.466667-19.2 42.666667-42.666667 42.666666s-42.666667-19.2-42.666666-42.666666V42.666667c0-23.466667 19.2-42.666667 42.666666-42.666667s42.666667 19.2 42.666667 42.666667 M806.1952 457.275733L550.5792 712.900267a42.7776 42.7776 0 0 1-60.330667 0c-16.597333-16.605867-16.597333-43.776 0-60.330667l255.616-255.624533a42.7776 42.7776 0 0 1 60.330667 0 42.7776 42.7776 0 0 1 0 60.330666 M490.350933 712.8832L234.734933 457.275733a42.7776 42.7776 0 0 1 0-60.330666c16.597333-16.605867 43.776-16.605867 60.330667 0l255.616 255.616a42.7776 42.7776 0 0 1 0 60.330666 42.7776 42.7776 0 0 1-60.330667 0 M904.533333 1024H136.533333c-70.570667 0-128-57.429333-128-128V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666667 42.666667v256c0 23.552 19.114667 42.666667 42.666666 42.666667h768c23.552 0 42.666667-19.114667 42.666667-42.666667V640c0-23.594667 19.072-42.666667 42.666667-42.666667s42.666667 19.072 42.666666 42.666667v256c0 70.570667-57.429333 128-128 128" 
                              Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/>
                </Button>
                
                <Button Theme="{StaticResource RobustPlainIconBtn}"
                        Command="{Binding OpenFolderCommand}"
                        ToolTip.Tip="打开 Mod 文件夹">
                    <PathIcon Data="M928 352v-48c0-35.3-28.7-64-64-64H485.2c-21 0-40.7-10.3-52.6-27.6l-61.5-88.9c-12-17.3-31.6-27.6-52.6-27.6H64c-35.3 0-64 28.7-64 64v656c0 70.7 57.3 128 128 128h638c57.8 0 108.5-38.8 123.6-94.6L928 707.2l74.2-274.5c11-40.7-19.6-80.7-61.8-80.7H928zM80 160h230.1c5.3 0 10.2 2.6 13.2 6.9l50.6 73.1H80c-8.8 0-16-7.2-16-16v-48c0-8.8 7.2-16 16-16z m0 144h768c8.8 0 16 7.2 16 16v32H209c-28.9 0-54.2 19.4-61.8 47.3L79.7 649c-2.4 9-15.7 7.3-15.7-2.1V320c0-8.8 7.2-16 16-16z m784 394.7l-36.2 134c-7.5 27.9-32.9 47.3-61.8 47.3H125.4c-21.1 0-36.4-20-30.9-40.3l111.3-411.8c1.9-7 8.2-11.8 15.4-11.8h698.3c10.5 0 18.2 10 15.4 20.2l-7 25.7L864 698.7z" 
                              Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/>
                </Button>
                
                <Button Theme="{StaticResource RobustPlainIconBtn}"
                        Command="{Binding RefreshModListCommand}"
                        ToolTip.Tip="刷新 Mod 列表">
                    <PathIcon Data="M369.777778 160.568889a42.666667 42.666667 0 0 1-42.666667 42.666667H128a42.666667 42.666667 0 1 1 0-85.333334h199.111111a42.666667 42.666667 0 0 1 42.666667 42.666667 M327.111111 402.346667a42.666667 42.666667 0 0 1-42.666667-42.666667v-199.111111a42.666667 42.666667 0 1 1 85.333334 0v199.111111a42.666667 42.666667 0 0 1-42.666667 42.666667 M512.014222 938.652444h-0.753778a424.533333 424.533333 0 0 1-294.272-124.913777c-80.583111-80.583111-124.956444-187.733333-124.956444-301.696 0-113.976889 44.373333-221.112889 124.970667-301.696l73.088-73.116445a42.680889 42.680889 0 0 1 60.359111 60.344889l-73.102222 73.102222a339.057778 339.057778 0 0 0-99.982223 241.351111A339.128889 339.128889 0 0 0 277.333333 753.422222a339.640889 339.640889 0 0 0 235.406223 99.911111 42.680889 42.680889 0 0 1-0.725334 85.333334 M654.222222 863.473778v-0.014222a42.666667 42.666667 0 0 1 42.666667-42.666667h199.111111a42.666667 42.666667 0 0 1 0 85.333333H696.888889a42.666667 42.666667 0 0 1-42.666667-42.666666 M696.888889 621.681778a42.666667 42.666667 0 0 1 42.666667 42.666666v199.111112a42.666667 42.666667 0 0 1-85.333334 0v-199.111112a42.666667 42.666667 0 0 1 42.666667-42.666666 M703.715556 899.285333a42.638222 42.638222 0 0 1-30.165334-72.832l73.130667-73.102222c133.077333-133.091556 133.077333-349.653333 0-482.730667A339.100444 339.100444 0 0 0 505.315556 170.666667a42.666667 42.666667 0 1 1 0-85.333334c113.976889 0 221.112889 44.387556 301.681777 124.970667 166.357333 166.343111 166.357333 437.048889 0 603.377778l-73.102222 73.116444a42.524444 42.524444 0 0 1-30.165333 12.515556" 
                              Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 用外层 DockPanel 包裹：Button 固定在最下方，剩余空间用 Grid 包裹 -->
        <DockPanel Grid.Row="1">


            <Grid>
                <!-- 没安装 Melon Loader (缺少 Mods 文件夹) 时的状态面板 -->
                <StackPanel IsVisible="{Binding IsModsFolderMissing}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                    <TextBlock Text="请先安装Melon Loader" FontSize="18" Foreground="{DynamicResource ThemeTextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 更新列表为空时显示的状态面板 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsUpdateTabEmpty"/>
                            <Binding Path="!IsModsFolderMissing"/>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <TextBlock Text="当前没有可用的更新哦" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 本地列表为空时的状态面板 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsLocalTabEmpty"/>
                            <Binding Path="!IsModsFolderMissing"/>
                            <Binding Path="IsLocalTabSelected"/>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <TextBlock Text="请前往下载或导入mod" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer IsVisible="{Binding !IsModsFolderMissing}">
                    <ItemsControl ItemsSource="{Binding Mods}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:LocalMod">
                            <Border Background="{DynamicResource ModCardBgBrush}" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <Button Command="{Binding ToggleExpandCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Cursor="Hand">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                            <Style Selector="Button:pressed /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                        </Button.Styles>
                                        
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                                    <!-- 普通名字（非待删除） -->
                                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               IsVisible="{Binding !IsPendingDelete}"
                                                               helpers:TextBlockHelper.HighlightText="{Binding Name}"
                                                               helpers:TextBlockHelper.SearchText="{Binding $parent[UserControl].((vm:ModManagerViewModel)DataContext).SearchText}"/>
                                                    <!-- 待删除：红色加粗 -->
                                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="Red"
                                                               IsVisible="{Binding IsPendingDelete}"
                                                               Text="{Binding Name}"/>
                                                    <!-- 暂存标记 * -->
                                                    <TextBlock Text=" *" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               IsVisible="{Binding IsStaged}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                </StackPanel>
                                                <!-- 待删除提示文字 -->
                                                <TextBlock Text="将在游戏关闭后自动删除" IsVisible="{Binding IsPendingDelete}"
                                                           Foreground="Red" FontSize="12" Margin="0,3,0,0"/>
                                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                                                    <TextBlock Text="{Binding Version, StringFormat='版本: {0}'}" Foreground="{DynamicResource ThemeTextSubBrush}"/>
                                                    <TextBlock Foreground="{DynamicResource ThemeTextSubBrush}"
                                                               helpers:TextBlockHelper.HighlightText="{Binding Author, StringFormat='作者: {0}'}"
                                                               helpers:TextBlockHelper.SearchText="{Binding $parent[UserControl].((vm:ModManagerViewModel)DataContext).SearchText}"/>
                                                </StackPanel>
                                                <TextBlock Text="已禁用" IsVisible="{Binding IsDisabled}" Foreground="Red" Margin="0,5,0,0"/>
                                                <!-- 本地/更新列表：有更新时显示远端版本号 -->
                                                <TextBlock Text="{Binding UpdateAvailableText}" IsVisible="{Binding HasUpdate}" Foreground="#FF00FF" Margin="0,5,0,0"/>
                                                <!-- 下载列表：已安装且无更新 → 最新版本 -->
                                                <TextBlock Text="最新版本" IsVisible="{Binding DownloadListIsUpToDate}" Foreground="#4EC94E" Margin="0,5,0,0"/>
                                                <!-- 下载列表：已安装但有更新 → 有更新可用（下载列表不显示版本号，只提示） -->
                                                <TextBlock Text="有更新可用" IsVisible="{Binding DownloadListHasUpdate}" Foreground="#FF00FF" Margin="0,5,0,0"/>
                                                <!-- 下载列表：未安装（仅在下载Tab且未安装时显示，本地/更新列表不会出现） -->
                                                <TextBlock Text="未安装" IsVisible="{Binding ShowNotInstalledBadge}" Foreground="{DynamicResource ThemeTextTertiaryBrush}" Margin="0,5,0,0"/>
                                                <!-- 占位：不兼容（逻辑待实现） -->
                                                <TextBlock Text="不兼容" IsVisible="{Binding IsIncompatible}" Foreground="Red" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="25" VerticalAlignment="Center" Margin="0,0,15,0">
                                                <!-- ===== 下载列表专属按钮区 ===== -->
                                                <!-- 前往详情页 按钮 -->
                                                <Button Theme="{StaticResource RobustPlainIconBtn}"
                                                        IsVisible="{Binding FilePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                                        Command="{Binding $parent[UserControl].((vm:ModManagerViewModel)DataContext).OpenHomePageCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="前往详情页"
                                                        Padding="10,0"
                                                        HorizontalContentAlignment="Center">
                                                    <PathIcon Width="24" Height="24" Foreground="{DynamicResource SvgIconBrush}"
