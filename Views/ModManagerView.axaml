                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Button>

                                    <!-- 展开后的详情区域 -->
                                    <StackPanel IsVisible="{Binding IsExpanded}" Margin="0,15,0,0">
                                        <Border Height="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="0,0,0,12"/>
                                        <!-- 加载中提示 -->
                                        <TextBlock Text="正在加载..."
                                                   IsVisible="{Binding IsLoadingDescription}"
                                                   Foreground="{DynamicResource ThemeTextTertiaryBrush}" FontSize="13" FontStyle="Italic"/>
                                        <!-- 描述文本 -->
                                        <TextBlock Text="{Binding Description}"
                                                   IsVisible="{Binding !IsLoadingDescription}"
                                                   Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>


            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
