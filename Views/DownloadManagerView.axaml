<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:models="using:MdModManager.Models"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:animated="clr-namespace:AnimatedImage.Avalonia;assembly=AnimatedImage.Avalonia"
             x:Class="MdModManager.Views.DownloadManagerView"
             x:DataType="vm:DownloadManagerViewModel">
    <UserControl.Resources>
        <!-- 强力隔离的主题 (没有 PART_ContentPresenter) -->
        <ControlTheme x:Key="RobustIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="RenderTransform" Value="scale(0.92)"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
        </ControlTheme>
        <!-- 小型圆角按钮主题 (彻底隔离影响，纯透明背景) -->
        <ControlTheme x:Key="SmallRoundBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- 头部 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <!-- 返回按钮 -->
            <Button Grid.Column="0"
                    Command="{Binding GoBackCommand}"
                    Theme="{StaticResource SmallRoundBtn}"
                    ToolTip.Tip="返回上一级">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                          Fill="{DynamicResource SvgIconBrush}" Stretch="Uniform" Width="22" Height="22" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" Spacing="4" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="下载列表" FontSize="22" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#FF00FF" Offset="0"/>
                            <GradientStop Color="#FF69B4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="管理正在下载的谱面" FontSize="12" Foreground="{DynamicResource ThemeTextSubBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Theme="{StaticResource RobustIconBtn}"
                        Width="36"
                        Height="36"
                        Command="{Binding TogglePauseResumeAllCommand}"
                        IsEnabled="{Binding Tasks.Count}"
                        ToolTip.Tip="{Binding PauseResumeAllText}">
                    <Panel Width="18" Height="18">
                        <PathIcon Data="M128 106.858667C128 94.976 137.621333 85.333333 149.12 85.333333h85.76c11.648 0 21.12 9.6 21.12 21.525334V917.12c0 11.882667-9.621333 21.525333-21.12 21.525333H149.12A21.290667 21.290667 0 0 1 128 917.141333V106.88z m640 0c0-11.882667 9.621333-21.525333 21.12-21.525334h85.76c11.648 0 21.12 9.6 21.12 21.525334V917.12c0 11.882667-9.621333 21.525333-21.12 21.525333h-85.76a21.290667 21.290667 0 0 1-21.12-21.525333V106.88z"
                                  Foreground="{DynamicResource SvgIconBrush}"
                                  Width="18"
                                  Height="18"
                                  IsVisible="{Binding IsBulkPauseMode}"/>
                        <PathIcon Data="M256 128v768l576-384z"
                                  Foreground="{DynamicResource SvgIconBrush}"
                                  Width="18"
                                  Height="18"
                                  IsVisible="{Binding !IsBulkPauseMode}"/>
                    </Panel>
                </Button>
                <Button Theme="{StaticResource RobustIconBtn}"
                        Width="36"
                        Height="36"
                        Command="{Binding CancelAllCommand}"
                        IsEnabled="{Binding Tasks.Count}"
                        ToolTip.Tip="取消所有任务">
                    <PathIcon Data="M1004.032007 907.639505l-395.605202-395.605201 395.605202-395.673468c12.902396-12.902396 19.967993-30.037323 19.967993-48.298651 0-18.158927-7.099731-35.259722-19.93386-48.059717A67.583977 67.583977 0 0 0 955.938156 0.000341c-18.295461 0-35.430388 7.099731-48.298651 19.967994L512.000171 415.573536 116.360836 19.968335A67.720511 67.720511 0 0 0 68.164585 0.000341C49.971525 0.000341 32.87073 7.100072 19.968335 19.968335A67.549844 67.549844 0 0 0 0.000341 68.096319c0 18.227194 7.065598 35.362122 19.967994 48.264517l395.673468 395.673468L19.968335 907.605372A67.720511 67.720511 0 0 0 0.000341 955.835756c0 18.193061 7.099731 35.327988 19.967994 48.196251 12.902396 12.868262 30.00319 19.967993 48.19625 19.967993 18.193061 0 35.327988-7.099731 48.196251-19.967993l395.673468-395.605202 395.605201 395.605202c12.868262 12.868262 30.037323 19.967993 48.230384 19.967993 18.227194 0 35.293855-7.099731 48.127984-19.93386a68.266644 68.266644 0 0 0 0-96.426635z"
                              Foreground="{DynamicResource SvgIconBrush}"
                              Width="18"
                              Height="18"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 列表 空状态 -->
        <TextBlock Grid.Row="1" Text="当前没有下载任务" Foreground="{DynamicResource ThemeTextSubBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !Tasks.Count}"/>

        <!-- 列表 -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DownloadTaskItem">
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" RowDefinitions="Auto, Auto">
                                <!-- 封面图 -->
                                <Border Grid.RowSpan="2" Grid.Column="0" Width="40" Height="40" Background="#333333" CornerRadius="4" Margin="0,0,15,0" ClipToBounds="True">
                                    <Panel>
                                        <TextBlock Text="🎵" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="#555555" IsVisible="{Binding !Chart.HasDisplayCoverSource}"/>
                                        <Image IsVisible="{Binding Chart.HasAnimatedDisplayCoverSource}" Stretch="UniformToFill" animated:ImageBehavior.AnimatedSource="{Binding Chart.AnimatedDisplayCoverSource}"/>
                                        <asyncImageLoader:AdvancedImage Source="{Binding Chart.StaticDisplayCoverSource}" Stretch="UniformToFill" IsVisible="{Binding Chart.HasStaticDisplayCoverSource}"/>
                                    </Panel>
                                </Border>

                                <!-- 标题 -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Chart.Title}" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" FontSize="16" VerticalAlignment="Bottom"/>
                                
                                <!-- 进度条 -->
                                <ProgressBar Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Progress}" 
                                             Foreground="{DynamicResource SvgIconBrush}" Background="#333333" Height="6" Margin="0,8,15,0" VerticalAlignment="Top"/>
                                
                                <!-- 状态和大小 -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Width="120">
                                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource ThemeTextSubBrush}" FontSize="13" TextAlignment="Right"/>
                                    <TextBlock Text="{Binding DownloadInfo}" Foreground="{DynamicResource ThemeTextTertiaryBrush}" FontSize="11" TextAlignment="Right"/>
                                    <!-- 错误文本 -->
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF7043" FontSize="11" TextAlignment="Right" IsVisible="{Binding IsError}" TextWrapping="Wrap" MaxWidth="150" Height="30" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 操作按钮 (替换为SVG图标) -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                    <Button Theme="{DynamicResource RobustIconBtn}" Width="32" Height="32"
                                            Command="{Binding $parent[UserControl].((vm:DownloadManagerViewModel)DataContext).PauseCommand}" 
                                            CommandParameter="{Binding}" 
                                            IsVisible="{Binding CanPause}" ToolTip.Tip="暂停">
                                        <PathIcon Data="M128 106.858667C128 94.976 137.621333 85.333333 149.12 85.333333h85.76c11.648 0 21.12 9.6 21.12 21.525334V917.12c0 11.882667-9.621333 21.525333-21.12 21.525333H149.12A21.290667 21.290667 0 0 1 128 917.141333V106.88z m640 0c0-11.882667 9.621333-21.525333 21.12-21.525334h85.76c11.648 0 21.12 9.6 21.12 21.525334V917.12c0 11.882667-9.621333 21.525333-21.12 21.525333h-85.76a21.290667 21.290667 0 0 1-21.12-21.525333V106.88z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                                    </Button>
                                    <Button Theme="{DynamicResource RobustIconBtn}" Width="32" Height="32"
                                            Command="{Binding $parent[UserControl].((vm:DownloadManagerViewModel)DataContext).ResumeCommand}" 
                                            CommandParameter="{Binding}" 
                                            IsVisible="{Binding CanResume}" ToolTip.Tip="继续">
                                        <PathIcon Data="M874.666667 85.333333h-128V42.666667c0-25.6-17.066667-42.666667-42.666667-42.666667s-42.666667 17.066667-42.666667 42.666667v42.666666h-298.666666V42.666667c0-25.6-17.066667-42.666667-42.666667-42.666667s-42.666667 17.066667-42.666667 42.666667v42.666666h-128C89.6 85.333333 42.666667 132.266667 42.666667 192v725.333333C42.666667 977.066667 89.6 1024 149.333333 1024h725.333334c59.733333 0 106.666667-46.933333 106.666666-106.666667v-725.333333C981.333333 132.266667 934.4 85.333333 874.666667 85.333333z m21.333333 832c0 12.8-8.533333 21.333333-21.333333 21.333334h-725.333334c-12.8 0-21.333333-8.533333-21.333333-21.333334v-725.333333c0-12.8 8.533333-21.333333 21.333333-21.333333h128v42.666666c0 25.6 17.066667 42.666667 42.666667 42.666667s42.666667-17.066667 42.666667-42.666667V170.666667h298.666666v42.666666c0 25.6 17.066667 42.666667 42.666667 42.666667s42.666667-17.066667 42.666667-42.666667V170.666667h128c12.8 0 21.333333 8.533333 21.333333 21.333333v725.333333zM695.466667 537.6l-221.866667-162.133333c-21.333333-12.8-46.933333-17.066667-68.266667-4.266667-25.6 12.8-42.666667 38.4-42.666666 64v324.266667c0 29.866667 17.066667 55.466667 38.4 64 8.533333 4.266667 21.333333 8.533333 29.866666 8.533333 12.8 0 25.6-4.266667 38.4-12.8l221.866667-162.133333c17.066667-12.8 29.866667-34.133333 29.866667-59.733334 4.266667-25.6-8.533333-46.933333-25.6-59.733333z m-247.466667 192v-268.8l183.466667 132.266667-183.466667 136.533333z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                                    </Button>
                                    <Button Theme="{DynamicResource RobustIconBtn}" Width="32" Height="32"
                                            Command="{Binding $parent[UserControl].((vm:DownloadManagerViewModel)DataContext).CancelCommand}" 
                                            CommandParameter="{Binding}" 
                                            IsEnabled="{Binding !IsCompleted}" ToolTip.Tip="取消">
                                        <PathIcon Data="M1004.032007 907.639505l-395.605202-395.605201 395.605202-395.673468c12.902396-12.902396 19.967993-30.037323 19.967993-48.298651 0-18.158927-7.099731-35.259722-19.93386-48.059717A67.583977 67.583977 0 0 0 955.938156 0.000341c-18.295461 0-35.430388 7.099731-48.298651 19.967994L512.000171 415.573536 116.360836 19.968335A67.720511 67.720511 0 0 0 68.164585 0.000341C49.971525 0.000341 32.87073 7.100072 19.968335 19.968335A67.549844 67.549844 0 0 0 0.000341 68.096319c0 18.227194 7.065598 35.362122 19.967994 48.264517l395.673468 395.673468L19.968335 907.605372A67.720511 67.720511 0 0 0 0.000341 955.835756c0 18.193061 7.099731 35.327988 19.967994 48.196251 12.902396 12.868262 30.00319 19.967993 48.19625 19.967993 18.193061 0 35.327988-7.099731 48.196251-19.967993l395.673468-395.605202 395.605201 395.605202c12.868262 12.868262 30.037323 19.967993 48.230384 19.967993 18.227194 0 35.293855-7.099731 48.127984-19.93386a68.266644 68.266644 0 0 0 0-96.426635z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
