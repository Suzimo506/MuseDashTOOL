<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:models="using:MdModManager.Models"
             xmlns:controls="using:MdModManager.Views.Controls"
             xmlns:helpers="using:MdModManager.Helpers"
             x:Class="MdModManager.Views.AlbumCollectionView"
             x:DataType="vm:AlbumCollectionViewModel">

    <UserControl.Resources>
        <!-- 通用按钮主题 (带圆角和基本的悬浮缩放效果) -->
        <ControlTheme x:Key="SmallRoundBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>

        <!-- 纯图标按钮主题 (无边距、无背景、彻底隔离系统悬停灰色背景) -->
        <!-- 注意：此处不使用 PART_ContentPresenter 以避免 Avalonia 默认样式的干扰 -->
        <ControlTheme x:Key="RobustPlainIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.Card:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardHoverBgBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" PointerPressed="OnBackgroundPointerPressed" Background="Transparent">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="10,10,10,14">
            <Panel Grid.Column="0" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}"
                        IsVisible="{Binding !IsSearching}"
                        Theme="{StaticResource SmallRoundBtn}"
                        ToolTip.Tip="返回谱面下载">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                              Fill="{DynamicResource SvgIconBrush}"
                              Stretch="Uniform"
                              Width="22"
                              Height="22"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding IsSearching}"
                        Theme="{StaticResource SmallRoundBtn}"
                        ToolTip.Tip="返回整合包列表">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                              Fill="{DynamicResource SvgIconBrush}"
                              Stretch="Uniform"
                              Width="22"
                              Height="22"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Panel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                <TextBlock Text="整合包"
                           FontSize="22"
                           FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#FF00FF" Offset="0"/>
                            <GradientStop Color="#FF69B4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <!-- 搜索结果计数或下载/试听状态 -->
                <TextBlock Text="{Binding StatusMessage}" 
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                           FontSize="12" 
                           FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextTertiaryBrush}" 
                           Margin="0,2,0,0"/>
            </StackPanel>
            
            <!-- 搜索框 (样式同步自谱面下载界面) -->
            <TextBox Grid.Column="2" 
                     Width="300"
                     Text="{Binding SearchText}"
                     Watermark="搜索整合包内的谱面名称、作者..."
                     VerticalAlignment="Center"
                     Padding="10,8">
                <TextBox.InnerLeftContent>
                    <PathIcon Data="M909.6 854.5L649.9 594.8C690.2 542.7 712 479 712 412c0-80.2-31.3-155.4-87.9-212.1C567.2 143.9 492.3 112 413 112s-154.2 31.9-211.1 88.9C145.5 257.5 114 332.7 114 412c0 79.3 31.3 154.5 88 211.4C259.3 680.3 334.4 712 413 712c67 0 130.6-21.8 182.7-62l259.7 259.6a8.2 8.2 0 0 0 11.6 0l42.6-42.6a8.2 8.2 0 0 0 0-11.5zM570.4 570.4C528 612.7 471.8 636 412 636s-116-23.3-158.4-65.6C211.3 528 188 471.8 188 412s23.3-116.1 65.6-158.4C296 211.3 352.2 188 412 188s116.1 23.2 158.4 65.6S636 352.2 636 412s-23.3 116.1-65.6 158.4z"
                               Foreground="#888888" Width="16" Height="16" Margin="4,0,0,0"/>
                </TextBox.InnerLeftContent>
                <TextBox.InnerRightContent>
                    <!-- 这里的 Theme 已改为 StaticResource RobustPlainIconBtn 以消除悬停灰色背景 -->
                    <Button Command="{Binding ClearSearchCommand}"
                            IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Theme="{StaticResource RobustPlainIconBtn}" 
                            Margin="0,0,10,0">
                        <TextBlock Text="清空" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource SvgIconBrush}"/>
                    </Button>
                </TextBox.InnerRightContent>
            </TextBox>
        </Grid>

        <Grid Grid.Row="1">
            <!-- 正在加载提示 -->
            <StackPanel IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="正在加载整合包..."
                           FontSize="18"
                           Foreground="#888888"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 空列表提示 -->
            <StackPanel IsVisible="{Binding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="15">
                <TextBlock Text="暂时没有整合包"
                           FontSize="18"
                           Foreground="Gray"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 这里移除了 IsVisible="{Binding !IsSearching}"，确保搜索时文件夹列表依然可见 -->
            <ScrollViewer x:Name="AlbumScrollViewer"
                           HorizontalScrollBarVisibility="Disabled"
                           VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,20">
                    <!-- 搜索出来的谱面列表 (仅在搜索且有结果时显示) -->
                    <StackPanel IsVisible="{Binding HasSearchResults}" Margin="10,0,10,20">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MdmcChart">
                                    <Border Classes="Card" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Margin="8,0,8,16" VerticalAlignment="Top" ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Grid.Row="0" Height="170" ClipToBounds="True" CornerRadius="10,10,0,0">
                                                <Panel>
                                                    <Border Background="#333333" CornerRadius="10,10,0,0" IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"><TextBlock Text="🎵" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555555"/></Border>
                                                    <Image Source="{Binding CoverImage}" IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Border IsVisible="{Binding IsPlaying}" Background="#80000000" CornerRadius="10,10,0,0"><TextBlock Text="▶ 试听中" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="12,10,12,10" Spacing="4">
                                                <controls:MarqueeText Text="{Binding Title}" HighlightText="{Binding Title}" SearchText="{Binding SearchText}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" Height="20" ToolTip.Tip="{Binding Title}"/>
                                                
                                                <!-- 曲师 & 谱师信息 (强制单行) -->
                                                <TextBlock helpers:TextBlockHelper.HighlightText="{Binding SubInfo}" 
                                                           helpers:TextBlockHelper.SearchText="{Binding SearchText}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource ThemeTextSubBrush}" 
                                                           TextWrapping="NoWrap" 
                                                           TextTrimming="CharacterEllipsis"
                                                           Height="16"
                                                           ToolTip.Tip="{Binding SubInfo}"/>

                                                <!-- BPM & 难度标签 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Spacing="8" MinHeight="16">
                                                    <TextBlock Text="{Binding Bpm, StringFormat='BPM: \{0\}'}" IsVisible="{Binding Bpm, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="11" Foreground="{DynamicResource ThemeTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                    <ItemsControl ItemsSource="{Binding DifficultyLabels}" VerticalAlignment="Center">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate><DataTemplate><Border Background="#331a3a1a" CornerRadius="3" Padding="4,1"><TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource SvgIconBrush}"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                                    <Button Grid.Column="0" Theme="{StaticResource RobustPlainIconBtn}" HorizontalAlignment="Center" Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).TogglePreviewCommand}" CommandParameter="{Binding}" ToolTip.Tip="试听 / 停止"><Panel><PathIcon IsVisible="{Binding !IsPlaying}" Data="M896 512L128 1024V0z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/><PathIcon IsVisible="{Binding IsPlaying}" Data="M722.9375 933.875H301.0625a210.9375 210.9375 0 0 1-210.9375-210.9375V301.0625a210.9375 210.9375 0 0 1 210.9375-210.9375h421.875a210.9375 210.9375 0 0 1 210.9375 210.9375v421.875a210.9375 210.9375 0 0 1-210.9375 210.9375z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/></Panel></Button>
                                                    <Button Grid.Column="1" Theme="{StaticResource RobustPlainIconBtn}" HorizontalAlignment="Center" Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).DownloadChartCommand}" CommandParameter="{Binding}" ToolTip.Tip="下载到 Custom_Albums"><PathIcon Data="M498.347 824.32l-296.96-296.96c-11.947-11.947-3.414-34.133 13.653-34.133h160.427c11.946 0 20.48-8.534 20.48-20.48V54.613c0-11.946 8.533-20.48 20.48-20.48h189.44c11.946 0 20.48 8.534 20.48 20.48v418.134c0 11.946 8.533 20.48 20.48 20.48h160.426c18.774 0 27.307 22.186 13.654 34.133L525.653 824.32c-6.826 6.827-20.48 6.827-27.306 0zM916.48 989.867H107.52c-18.773 0-35.84-15.36-35.84-35.84 0-18.774 15.36-35.84 35.84-35.84h810.667c18.773 0 35.84 15.36 35.84 35.84-1.707 20.48-17.067 35.84-37.547 35.84z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/></Button>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- 底部分页控制栏 -->
                        <Border Background="Transparent" Margin="10,20,10,0" Padding="15,8" CornerRadius="10" IsVisible="{Binding TotalPages, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                                <Button Command="{Binding LoadFirstPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="第一页"><PathIcon Data="M321.53 929m-41.47 0l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47Z M787.26 170L411.44 514.25l375.82 344.21a39.32 39.32 0 0 1 13.11 29c0 36.51-48.2 54.79-76.38 29L348.17 572.2c-34.95-32-34.95-83.9 0-115.9L724 112.08c28.18-25.81 76.38-7.53 76.38 29A39.33 39.33 0 0 1 787.26 170z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/></Button>
                                <Button Command="{Binding LoadPrevPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="上一页"><PathIcon Data="M704 944c-10.88 0-22.4-3.84-31.36-11.52l-448-384c-10.88-8.96-16.64-22.4-16.64-36.48s6.4-27.52 16.64-36.48l448-384c19.84-17.28 50.56-14.72 67.84 5.12s14.72 50.56-5.12 67.84L329.6 512l405.76 347.52c19.84 17.28 22.4 47.36 5.12 67.84-9.6 10.88-23.04 16.64-36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/></Button>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"><TextBlock Text="第" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/><Panel VerticalAlignment="Center"><TextBlock Text="{Binding CurrentPage}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="14" Cursor="Hand" PointerPressed="OnPageNumberClick" IsVisible="{Binding !IsEditingPageNumber}"/><TextBox Name="PageJumpTextBox_Bottom" Text="{Binding JumpPageText}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="14" Width="50" Height="28" Padding="4,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" CornerRadius="4" LostFocus="OnPageJumpLostFocus" IsVisible="{Binding IsEditingPageNumber}" Background="{DynamicResource ControlBgBrush}"><TextBox.KeyBindings><KeyBinding Command="{Binding JumpPageCommand}" Gesture="Enter"/><KeyBinding Command="{Binding CancelEditPageCommand}" Gesture="Escape"/></TextBox.KeyBindings></TextBox></Panel><TextBlock Text="/" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/><TextBlock Text="{Binding TotalPages}" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/><TextBlock Text="页" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="13"/></StackPanel>
                                <Button Command="{Binding LoadNextPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="下一页"><PathIcon Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="18" Height="18"/></Button>
                                <Button Command="{Binding LoadLastPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="最末页"><PathIcon Data="M706.19 106m41.47 0l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47Z M240.46 865l375.81-344.25-375.81-344.21a39.32 39.32 0 0 1-13.11-29c0-36.51 48.2-54.79 76.38-29L679.55 462.8c35 32 35 83.9 0 115.9L303.73 922.92c-28.18 25.81-76.38 7.53-76.38-29A39.33 39.33 0 0 1 240.46 865z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/></Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 分隔符 (仅在搜索且有结果时显示) -->
                    <StackPanel IsVisible="{Binding HasSearchResults}" Margin="18,0,18,20">
                        <TextBlock Text="出自以下整合包" 
                                   FontSize="15" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource ThemeTextSubBrush}"/>
                        <Border Height="1" 
                                Background="{DynamicResource ThemeTextTertiaryBrush}" 
                                Opacity="0.15" 
                                Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 官方/设计师分类列表 -->
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCategoryCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Margin="8,8,8,16"
                                        Cursor="Hand">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding Category.Description}" 
                                                   FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                                   FontSize="13"/>
                                    </ToolTip.Tip>
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </Button.Styles>
                                    <Border Classes="Card"
                                            Background="{DynamicResource CardBgBrush}"
                                            CornerRadius="10"
                                            ClipToBounds="True">
                                        <Grid RowDefinitions="180,*">
                                            <Border Grid.Row="0" ClipToBounds="True" Background="#333333">
                                                <Panel>
                                                    <TextBlock Text="📁"
                                                               FontSize="56"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="#555555"
                                                               IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                </Panel>
                                            </Border>

                                            <StackPanel Grid.Row="1" Margin="12,12,12,14" Spacing="6">
                                                <TextBlock Text="{Binding Category.Name}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemeTextMainBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 群友自制谱面区域：搜索时不显示标题和分割线 -->
                    <StackPanel Margin="8,4,8,24" Spacing="14">
                        <StackPanel IsVisible="{Binding !IsSearching}">
                            <Border Height="1"
                                    Background="{DynamicResource ThemeTextTertiaryBrush}"
                                    Opacity="0.25"/>
                            <TextBlock Text="群友自制谱面"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,14,0,0"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        </StackPanel>
                        
                        <ItemsControl ItemsSource="{Binding CommunityCategories}" IsVisible="{Binding CommunityCategories.Count}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCommunityCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Margin="8,0,8,16"
                                            Cursor="Hand">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                        </Button.Styles>
                                        <Border Classes="Card"
                                                Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Grid RowDefinitions="180,*">
                                                <Border Grid.Row="0" ClipToBounds="True" Background="#333333">
                                                    <Panel>
                                                        <TextBlock Text="📁"
                                                                   FontSize="56"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#555555"
                                                                   IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12,12,12,14" Spacing="6">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
