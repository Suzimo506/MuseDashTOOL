<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MdModManager.ViewModels"
             xmlns:models="using:MdModManager.Models"
             xmlns:controls="using:MdModManager.Views.Controls"
             xmlns:helpers="using:MdModManager.Helpers"
             x:Class="MdModManager.Views.AlbumCollectionView"
             x:DataType="vm:AlbumCollectionViewModel">

    <UserControl.Resources>
        <!-- 通用按钮主题 (带圆角和基本的悬浮缩放效果) -->
        <ControlTheme x:Key="SmallRoundBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>

        <!-- 纯图标按钮主题 (无边距、无背景、彻底隔离系统悬停灰色背景) -->
        <!-- 注意：此处不使用 PART_ContentPresenter 以避免 Avalonia 默认样式的干扰 -->
        <ControlTheme x:Key="RobustPlainIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBorder">
                <Setter Property="Opacity" Value="0.6"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.Card:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardHoverBgBrush}"/>
        </Style>
        <Style Selector="Button.ListRow:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" PointerPressed="OnBackgroundPointerPressed" Background="Transparent">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="10,10,10,14">
            <Panel Grid.Column="0" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}"
                        IsVisible="{Binding !IsSearching}"
                        Theme="{StaticResource SmallRoundBtn}"
                        ToolTip.Tip="返回谱面下载">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                              Fill="{DynamicResource SvgIconBrush}"
                              Stretch="Uniform"
                              Width="22"
                              Height="22"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding IsSearching}"
                        Theme="{StaticResource SmallRoundBtn}"
                        ToolTip.Tip="返回整合包列表">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                              Fill="{DynamicResource SvgIconBrush}"
                              Stretch="Uniform"
                              Width="22"
                              Height="22"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Panel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0" Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="整合包"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#FF00FF" Offset="0"/>
                                <GradientStop Color="#FF69B4" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <Button IsVisible="{Binding !IsSearching}"
                            Theme="{StaticResource SmallRoundBtn}"
                            ToolTip.Tip="跳转分类"
                            VerticalAlignment="Center"
                            Padding="8,5">
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel Spacing="8" Margin="4">
                                    <Button Theme="{StaticResource SmallRoundBtn}" Click="OnJumpToCategoryClick" Tag="pack">
                                        <TextBlock Text="曲包"/>
                                    </Button>
                                    <Button Theme="{StaticResource SmallRoundBtn}" Click="OnJumpToCategoryClick" Tag="personal">
                                        <TextBlock Text="谱师个人仓库"/>
                                    </Button>
                                    <Button Theme="{StaticResource SmallRoundBtn}" Click="OnJumpToCategoryClick" Tag="community">
                                        <TextBlock Text="群友自制谱面"/>
                                    </Button>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <PathIcon Data="M128 213.333333h170.666667a42.666667 42.666667 0 1 0 0-85.333333H128a42.666667 42.666667 0 1 0 0 85.333333zM128 554.666667h213.333333a42.666667 42.666667 0 0 0 0-85.333334H128a42.666667 42.666667 0 0 0 0 85.333334zM938.666667 304.768C938.666667 157.269333 824.064 42.666667 676.565333 42.666667 539.050667 42.666667 426.666667 159.573333 426.666667 304.768 426.666667 440.021333 541.269333 554.666667 676.565333 554.666667 821.76 554.666667 938.666667 442.282667 938.666667 304.768z m-426.666667 0C512 205.952 586.965333 128 676.565333 128 776.96 128 853.333333 204.373333 853.333333 304.768 853.333333 394.368 775.381333 469.333333 676.565333 469.333333 588.416 469.333333 512 392.96 512 304.768zM128 896h597.333333a42.666667 42.666667 0 0 0 0-85.333333H128a42.666667 42.666667 0 0 0 0 85.333333zM728.746667 528.810667l128 298.666666a42.666667 42.666667 0 1 0 78.506666-33.621333l-128-298.666667a42.666667 42.666667 0 1 0-78.506666 33.621334z"
                                  Foreground="{DynamicResource SvgIconBrush}"
                                  Width="20"
                                  Height="20"/>
                    </Button>
                </StackPanel>
                <!-- 搜索结果计数或下载/试听状态 -->
                <TextBlock Text="{Binding StatusMessage}" 
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                           FontSize="12" 
                           FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextTertiaryBrush}" 
                           Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                <Canvas Width="22" Height="22" Margin="110,0,15,0" ClipToBounds="False">
                    <Border IsVisible="{Binding ShowViewModeGuide}"
                            Background="#FFF6D76B"
                            CornerRadius="10"
                            Padding="8,3"
                            Canvas.Left="-88"
                            Canvas.Top="-2">
                        <TextBlock Text="试试列表模式"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#5A4200"/>
                    </Border>
                    <Button Command="{Binding ToggleListModeCommand}"
                            Theme="{StaticResource RobustPlainIconBtn}"
                            ToolTip.Tip="{Binding ViewModeToolTip}"
                            Canvas.Left="0"
                            Canvas.Top="0">
                        <Grid ClipToBounds="False">
                            <PathIcon Data="{Binding ViewModeIconData}"
                                      Foreground="{DynamicResource SvgIconBrush}"
                                      Width="22"
                                      Height="22"/>
                            <Border IsVisible="{Binding ShowViewModeGuide}"
                                    Width="10"
                                    Height="10"
                                    CornerRadius="5"
                                    Background="#FF5AC8FA"
                                    BorderBrush="#FFFDF3C9"
                                    BorderThickness="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-2,-4,0"/>
                        </Grid>
                    </Button>
                </Canvas>

                <!-- 下载 Pictures 按钮 -->
                <Button Command="{Binding DownloadPicturesCommand}"
                        Theme="{StaticResource RobustPlainIconBtn}"
                        Margin="0,0,15,0"
                        ToolTip.Tip="下载曲包封面（文件稍大）">
                    <PathIcon Data="M1133.095385 293.809231l0.472615 0.630154-518.774154 411.096615L356.824615 557.686154 94.523077 743.660308v166.439384H630.153846V1008.246154H0V0h1134.276923v293.809231h-1.181538zM1039.753846 248.201846V98.146462h-945.230769V627.790769l256.866461-182.114461L606.286769 591.556923l433.467077-343.433846zM354.461538 393.846154a118.153846 118.153846 0 1 1 0-236.307692 118.153846 118.153846 0 0 1 0 236.307692z m0-78.769231a39.384615 39.384615 0 1 0 0-78.769231 39.384615 39.384615 0 0 0 0 78.769231z m661.110154 511.763692l139.657846-139.657846 66.481231 66.481231-253.636923 253.636923h-0.787692L714.436923 754.215385l66.166154-66.166154 141.233231 141.312-6.537846-288.689231 93.735384 0.236308 6.616616 285.932307z" 
                              Foreground="{DynamicResource SvgIconBrush}" 
                              Width="22" Height="22"/>
                </Button>

                <!-- 下载列表入口按钮 -->
                <Button Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateToDownloadManagerCommand}"
                        Theme="{StaticResource RobustPlainIconBtn}"
                        ToolTip.Tip="下载列表">
                    <PathIcon Data="M392 160h-304C75.2 160 64 148.8 64 136S75.2 112 88 112h304c12.8 0 24 11.2 24 24s-11.2 24-24 24zM360 411.2h-272c-12.8 0-24-11.2-24-24s11.2-24 24-24h272c12.8 0 24 11.2 24 24s-11.2 24-24 24zM488 660.8h-400c-12.8 0-24-11.2-24-24s11.2-24 24-24h400c12.8 0 24 11.2 24 24 0 14.4-11.2 24-24 24zM936 912h-848c-12.8 0-24-11.2-24-24S75.2 864 88 864h848c12.8 0 24 11.2 24 24s-11.2 24-24 24zM945.6 446.4c-9.6-9.6-24-9.6-33.6 0l-128 128V136c0-12.8-11.2-24-24-24S736 123.2 736 136v438.4L609.6 448c-9.6-9.6-24-9.6-33.6 0-9.6 9.6-9.6 24 0 33.6l168 168c1.6 1.6 4.8 3.2 8 4.8 3.2 1.6 6.4 1.6 8 1.6s6.4 0 8-1.6c3.2-1.6 6.4-3.2 8-4.8L944 481.6c9.6-9.6 9.6-25.6 1.6-35.2z" 
                              Foreground="{DynamicResource SvgIconBrush}" 
                              Width="22" Height="22"/>
                </Button>
            </StackPanel>
            
            <!-- 搜索框 (样式同步自谱面下载界面) -->
            <TextBox Grid.Column="3" 
                     Width="300"
                     Text="{Binding SearchText}"
                     Watermark="搜索整合包内的谱面名称、作者..."
                     VerticalAlignment="Center"
                     Padding="10,8"
                     KeyDown="OnSearchBoxKeyDown">
                <TextBox.InnerLeftContent>
                    <PathIcon Data="M909.6 854.5L649.9 594.8C690.2 542.7 712 479 712 412c0-80.2-31.3-155.4-87.9-212.1C567.2 143.9 492.3 112 413 112s-154.2 31.9-211.1 88.9C145.5 257.5 114 332.7 114 412c0 79.3 31.3 154.5 88 211.4C259.3 680.3 334.4 712 413 712c67 0 130.6-21.8 182.7-62l259.7 259.6a8.2 8.2 0 0 0 11.6 0l42.6-42.6a8.2 8.2 0 0 0 0-11.5zM570.4 570.4C528 612.7 471.8 636 412 636s-116-23.3-158.4-65.6C211.3 528 188 471.8 188 412s23.3-116.1 65.6-158.4C296 211.3 352.2 188 412 188s116.1 23.2 158.4 65.6S636 352.2 636 412s-23.3 116.1-65.6 158.4z"
                               Foreground="#888888" Width="16" Height="16" Margin="4,0,0,0"/>
                </TextBox.InnerLeftContent>
                <TextBox.InnerRightContent>
                    <!-- 这里的 Theme 已改为 StaticResource RobustPlainIconBtn 以消除悬停灰色背景 -->
                    <Button Command="{Binding ClearSearchCommand}"
                            IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Theme="{StaticResource RobustPlainIconBtn}" 
                            Margin="0,0,10,0">
                        <TextBlock Text="清空" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource SvgIconBrush}"/>
                    </Button>
                </TextBox.InnerRightContent>
            </TextBox>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <!-- 搜索结果固定分页栏 -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Margin="20,0,20,12"
                    Padding="12,6"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    IsVisible="{Binding HasSearchResults}">
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <Button Command="{Binding LoadFirstPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="第一页">
                        <PathIcon Data="M321.53 929m-41.47 0l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47Z M787.26 170L411.44 514.25l375.82 344.21a39.32 39.32 0 0 1 13.11 29c0 36.51-48.2 54.79-76.38 29L348.17 572.2c-34.95-32-34.95-83.9 0-115.9L724 112.08c28.18-25.81 76.38-7.53 76.38 29A39.33 39.33 0 0 1 787.26 170z" Foreground="{DynamicResource SvgIconBrush}" Width="14" Height="14"/>
                    </Button>
                    <Button Command="{Binding LoadPrevPageCommand}" IsEnabled="{Binding CanLoadPrev}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="上一页">
                        <PathIcon Data="M704 944c-10.88 0-22.4-3.84-31.36-11.52l-448-384c-10.88-8.96-16.64-22.4-16.64-36.48s6.4-27.52 16.64-36.48l448-384c19.84-17.28 50.56-14.72 67.84 5.12s14.72 50.56-5.12 67.84L329.6 512l405.76 347.52c19.84 17.28 22.4 47.36 5.12 67.84-9.6 10.88-23.04 16.64-36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="4,0">
                        <TextBlock Text="第" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <Panel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPage}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="ExtraBold" FontSize="12" Cursor="Hand" PointerPressed="OnPageNumberClick" IsVisible="{Binding !IsEditingPageNumber}"/>
                            <TextBox Name="PageJumpTextBox_Top" Text="{Binding JumpPageText}" Foreground="{DynamicResource SvgIconBrush}" FontWeight="Bold" FontSize="12" Width="42" Height="22" Padding="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="1" CornerRadius="4" LostFocus="OnPageJumpLostFocus" KeyDown="OnPageJumpKeyDown" IsVisible="{Binding IsEditingPageNumber}" Background="{DynamicResource ControlBgBrush}"/>
                        </Panel>
                        <TextBlock Text="/" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock Text="{Binding TotalPages}" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                        <TextBlock Text="页" Foreground="{DynamicResource ThemeTextSubBrush}" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                    <Button Command="{Binding LoadNextPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="下一页">
                        <PathIcon Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z" Foreground="{DynamicResource SvgIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding LoadLastPageCommand}" IsEnabled="{Binding CanLoadNext}" Theme="{StaticResource RobustPlainIconBtn}" ToolTip.Tip="最末页">
                        <PathIcon Data="M706.19 106m41.47 0l0 0q41.47 0 41.47 41.47l0 747.06q0 41.47-41.47 41.47l0 0q-41.47 0-41.47-41.47l0-747.06q0-41.47 41.47-41.47Z M240.46 865l375.81-344.25-375.81-344.21a39.32 39.32 0 0 1-13.11-29c0-36.51 48.2-54.79 76.38-29L679.55 462.8c35 32 35 83.9 0 115.9L303.73 922.92c-28.18 25.81-76.38 7.53-76.38-29A39.33 39.33 0 0 1 240.46 865z" Foreground="{DynamicResource SvgIconBrush}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 正在加载提示 -->
            <StackPanel Grid.Row="1"
                        IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="正在加载整合包..."
                           FontSize="18"
                           Foreground="#888888"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 空列表提示 -->
            <StackPanel Grid.Row="1"
                        IsVisible="{Binding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="15">
                <TextBlock Text="暂时没有整合包"
                           FontSize="18"
                           Foreground="Gray"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 这里移除了 IsVisible="{Binding !IsSearching}"，确保搜索时文件夹列表依然可见 -->
            <ScrollViewer Grid.Row="1"
                           x:Name="AlbumScrollViewer"
                           HorizontalScrollBarVisibility="Disabled"
                           VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,20">
                    <!-- 搜索出来的谱面列表 (仅在搜索且有结果时显示) -->
                    <StackPanel x:Name="SearchResultsAnchor" IsVisible="{Binding HasSearchResults}" Margin="10,0,10,20">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MdmcChart">
                                    <Border Classes="Card" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Margin="8,0,8,16" VerticalAlignment="Top" ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Grid.Row="0" Height="170" ClipToBounds="True" CornerRadius="10,10,0,0">
                                                <Panel>
                                                    <Border Background="#333333" CornerRadius="10,10,0,0" IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"><TextBlock Text="🎵" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555555"/></Border>
                                                    <Image Source="{Binding CoverImage}" IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Border IsVisible="{Binding IsPlaying}" Background="#80000000" CornerRadius="10,10,0,0"><TextBlock Text="▶ 试听中" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="12,10,12,10" Spacing="4">
                                                <controls:MarqueeText Text="{Binding Title}" HighlightText="{Binding Title}" SearchText="{Binding SearchText}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMainBrush}" Height="20" ToolTip.Tip="{Binding Title}"/>
                                                
                                                <!-- 曲师 & 谱师信息 (强制单行) -->
                                                <TextBlock helpers:TextBlockHelper.HighlightText="{Binding SubInfo}" 
                                                           helpers:TextBlockHelper.SearchText="{Binding SearchText}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource ThemeTextSubBrush}" 
                                                           TextWrapping="NoWrap" 
                                                           TextTrimming="CharacterEllipsis"
                                                           Height="16"
                                                           ToolTip.Tip="{Binding SubInfo}"/>

                                                <!-- BPM & 难度标签 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Spacing="8" MinHeight="16">
                                                    <TextBlock Text="{Binding Bpm, StringFormat='BPM: \{0\}'}" IsVisible="{Binding Bpm, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="11" Foreground="{DynamicResource ThemeTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                    <ItemsControl ItemsSource="{Binding DifficultyLabels}" VerticalAlignment="Center">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate><DataTemplate><Border Background="#331a3a1a" CornerRadius="3" Padding="4,1"><TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource SvgIconBrush}"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                                    <Button Grid.Column="0" Theme="{StaticResource RobustPlainIconBtn}" HorizontalAlignment="Center" Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).TogglePreviewCommand}" CommandParameter="{Binding}" ToolTip.Tip="试听 / 停止"><Panel><PathIcon IsVisible="{Binding !IsPlaying}" Data="M896 512L128 1024V0z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/><PathIcon IsVisible="{Binding IsPlaying}" Data="M722.9375 933.875H301.0625a210.9375 210.9375 0 0 1-210.9375-210.9375V301.0625a210.9375 210.9375 0 0 1 210.9375-210.9375h421.875a210.9375 210.9375 0 0 1 210.9375 210.9375v421.875a210.9375 210.9375 0 0 1-210.9375 210.9375z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/></Panel></Button>
                                                    <Button Grid.Column="1" Theme="{StaticResource RobustPlainIconBtn}" HorizontalAlignment="Center" Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenSearchResultCategoryCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开所在整合包"><PathIcon Width="24" Height="24" Foreground="{DynamicResource SvgIconBrush}" Data="M730.624 685.568c-142.25-8.107-278.357 14.848-408.49 72.277A773.803 773.803 0 0 0 0 1024c1.707-10.41 3.243-20.736 5.12-31.147a782.507 782.507 0 0 1 5.803-31.146C38.4 834.133 82.432 713.3 151.296 602.88c70.656-113.067 161.28-203.776 280.576-261.973a645.973 645.973 0 0 1 243.456-62.976c18.005-1.28 36.096-1.707 54.784-2.646V5.461l3.328-2.645 460.885 477.867-463.701 475.989V685.568z"/></Button>
                                                    <Button Grid.Column="2" Theme="{StaticResource RobustPlainIconBtn}" HorizontalAlignment="Center" Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).DownloadChartCommand}" CommandParameter="{Binding}" ToolTip.Tip="下载到 Custom_Albums"><PathIcon Data="M498.347 824.32l-296.96-296.96c-11.947-11.947-3.414-34.133 13.653-34.133h160.427c11.946 0 20.48-8.534 20.48-20.48V54.613c0-11.946 8.533-20.48 20.48-20.48h189.44c11.946 0 20.48 8.534 20.48 20.48v418.134c0 11.946 8.533 20.48 20.48 20.48h160.426c18.774 0 27.307 22.186 13.654 34.133L525.653 824.32c-6.826 6.827-20.48 6.827-27.306 0zM916.48 989.867H107.52c-18.773 0-35.84-15.36-35.84-35.84 0-18.774 15.36-35.84 35.84-35.84h810.667c18.773 0 35.84 15.36 35.84 35.84-1.707 20.48-17.067 35.84-37.547 35.84z" Foreground="{DynamicResource SvgIconBrush}" Width="20" Height="20"/></Button>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 分隔符 (仅在搜索且有结果时显示) -->
                    <StackPanel IsVisible="{Binding HasSearchResults}" Margin="18,0,18,20">
                        <TextBlock Text="出自以下整合包" 
                                   FontSize="15" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource ThemeTextSubBrush}"/>
                        <Border Height="1" 
                                Background="{DynamicResource ThemeTextTertiaryBrush}" 
                                Opacity="0.15" 
                                Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 曲包区域 -->
                    <StackPanel x:Name="PackSectionAnchor" Margin="8,4,8,24" Spacing="14">
                        <StackPanel IsVisible="{Binding !IsSearching}">
                            <Border Height="1"
                                    Background="{DynamicResource ThemeTextTertiaryBrush}"
                                    Opacity="0.25"/>
                            <TextBlock Text="曲包"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,14,0,0"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        </StackPanel>

                        <!-- 官方/设计师分类列表 -->
                        <ItemsControl ItemsSource="{Binding Categories}" IsVisible="{Binding !IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Margin="8,8,8,16"
                                            Cursor="Hand">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding Category.Description}" 
                                                       IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                                       FontSize="13"/>
                                        </ToolTip.Tip>
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                        </Button.Styles>
                                        <Border Classes="Card"
                                                Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Grid RowDefinitions="180,*">
                                                <Border Grid.Row="0" ClipToBounds="True" Background="#333333">
                                                    <Panel>
                                                        <TextBlock Text="📁"
                                                                   FontSize="56"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#555555"
                                                                   IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                </Border>

                                                <StackPanel Grid.Row="1" Margin="12,12,12,14" Spacing="6">
                                                    <TextBlock Text="{Binding Category.Name}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Categories}" IsVisible="{Binding IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="ListRow"
                                            Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            Margin="8,0,8,10"
                                            Cursor="Hand">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding Category.Description}"
                                                       IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                                       FontSize="13"/>
                                        </ToolTip.Tip>
                                        <Border Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                Padding="14,12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Category.Name}"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Category.Description}"
                                                               IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource ThemeTextSubBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <PathIcon Grid.Column="1"
                                                          Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z"
                                                          Width="16"
                                                          Height="16"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource ThemeTextTertiaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 谱师个人仓库区域：搜索时不显示标题和分割线 -->
                    <StackPanel x:Name="PersonalRepositorySectionAnchor" Margin="8,4,8,24" Spacing="14">
                        <StackPanel IsVisible="{Binding !IsSearching}">
                            <Border Height="1"
                                    Background="{DynamicResource ThemeTextTertiaryBrush}"
                                    Opacity="0.25"/>
                            <TextBlock Text="谱师个人仓库"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,14,0,0"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding PersonalRepositoryCategories}" IsVisible="{Binding !IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Margin="8,0,8,16"
                                            Cursor="Hand">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding Category.Description}" 
                                                       IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                                       FontSize="13"/>
                                        </ToolTip.Tip>
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                        </Button.Styles>
                                        <Border Classes="Card"
                                                Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Grid RowDefinitions="180,*">
                                                <Border Grid.Row="0" ClipToBounds="True" Background="#333333">
                                                    <Panel>
                                                        <TextBlock Text="📁"
                                                                   FontSize="56"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#555555"
                                                                   IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                </Border>

                                                <StackPanel Grid.Row="1" Margin="12,12,12,14" Spacing="6">
                                                    <TextBlock Text="{Binding Category.Name}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding PersonalRepositoryCategories}" IsVisible="{Binding IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="ListRow"
                                            Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            Margin="8,0,8,10"
                                            Cursor="Hand">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding Category.Description}"
                                                       IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                                       FontSize="13"/>
                                        </ToolTip.Tip>
                                        <Border Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                Padding="14,12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Category.Name}"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Category.Description}"
                                                               IsVisible="{Binding Category.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource ThemeTextSubBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <PathIcon Grid.Column="1"
                                                          Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z"
                                                          Width="16"
                                                          Height="16"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource ThemeTextTertiaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 群友自制谱面区域：搜索时不显示标题和分割线 -->
                    <StackPanel x:Name="CommunitySectionAnchor" Margin="8,4,8,24" Spacing="14">
                        <StackPanel IsVisible="{Binding !IsSearching}">
                            <Border Height="1"
                                    Background="{DynamicResource ThemeTextTertiaryBrush}"
                                    Opacity="0.25"/>
                            <TextBlock Text="群友自制谱面"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,14,0,0"
                                       HorizontalAlignment="Left"
                                       Foreground="{DynamicResource ThemeTextMainBrush}"/>
                        </StackPanel>
                        
                        <ItemsControl ItemsSource="{Binding CommunityCategories}" IsVisible="{Binding !IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCommunityCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Margin="8,0,8,16"
                                            Cursor="Hand">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                        </Button.Styles>
                                        <Border Classes="Card"
                                                Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Grid RowDefinitions="180,*">
                                                <Border Grid.Row="0" ClipToBounds="True" Background="#333333">
                                                    <Panel>
                                                        <TextBlock Text="📁"
                                                                   FontSize="56"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#555555"
                                                                   IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding CoverImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                    </Panel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12,12,12,14" Spacing="6">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding CommunityCategories}" IsVisible="{Binding IsListMode}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="ListRow"
                                            Command="{Binding $parent[UserControl].((vm:AlbumCollectionViewModel)DataContext).OpenCommunityCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            Margin="8,0,8,10"
                                            Cursor="Hand">
                                        <Border Background="{DynamicResource CardBgBrush}"
                                                CornerRadius="10"
                                                Padding="14,12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <TextBlock
                                                           Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemeTextMainBrush}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                                <PathIcon Grid.Column="1"
                                                          Data="M288 944c10.88 0 22.4-3.84 31.36-11.52l448-384c10.88-8.96 16.64-22.4 16.64-36.48s-6.4-27.52-16.64-36.48l-448-384c-19.84-17.28-50.56-14.72-67.84 5.12s-14.72 50.56 5.12 67.84L662.4 512l-405.76 347.52c-19.84 17.28-22.4 47.36-5.12 67.84 9.6 10.88 23.04 16.64 36.48 16.64z"
                                                          Width="16"
                                                          Height="16"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource ThemeTextTertiaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
