<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MdModManager.ViewModels"
             x:Class="MdModManager.Views.CommunityCategoryDetailView"
             x:DataType="vm:CommunityCategoryDetailViewModel">

    <UserControl.Resources>
        <ControlTheme x:Key="SmallRoundBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="RenderTransform" Value="scale(0.96)"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="DateTabBtn" TargetType="RadioButton">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMainBrush}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.85"/>
            </Style>
            <Style Selector="^:checked /template/ Border#RootBg">
                <Setter Property="Background" Value="{DynamicResource SvgIconBrush}"/>
            </Style>
            <Style Selector="^:checked">
                <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#RootBg">
                <Setter Property="Opacity" Value="0.65"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="10,10,0,14">
            <Button Grid.Column="0"
                    Command="{Binding GoBackCommand}"
                    Theme="{StaticResource SmallRoundBtn}"
                    ToolTip.Tip="返回整合包">
                <Path Data="M732.794579 1020.867765a58.608941 58.608941 0 0 1-41.803294-17.558589L247.478814 553.984a60.446118 60.446118 0 0 1 0-84.720941L690.991285 19.847529a58.578824 58.578824 0 0 1 83.606588 0 60.446118 60.446118 0 0 1 0 84.720942L372.979049 511.638588 774.597873 918.588235a60.446118 60.446118 0 0 1 0 84.720941 58.608941 58.608941 0 0 1-41.803294 17.558589z"
                      Fill="{DynamicResource SvgIconBrush}"
                      Stretch="Uniform"
                      Width="22"
                      Height="22"
                      VerticalAlignment="Center"/>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                <TextBlock Text="{Binding CategoryName}"
                           FontSize="22"
                           FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#FF00FF" Offset="0"/>
                            <GradientStop Color="#FF69B4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="点击跳转下载后密码自动复制"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeTextSubBrush}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="10,0,10,18">
            <RadioButton Theme="{StaticResource DateTabBtn}"
                         GroupName="CommunityDates"
                         IsChecked="{Binding IsDate202311Selected, Mode=OneWay}"
                         Command="{Binding SelectDateCommand}"
                         CommandParameter="2023-11"
                         Content="2023-11"/>
            <RadioButton Theme="{StaticResource DateTabBtn}"
                         GroupName="CommunityDates"
                         IsChecked="{Binding IsDate202406Selected, Mode=OneWay}"
                         Command="{Binding SelectDateCommand}"
                         CommandParameter="2024-6"
                         Content="2024-6"/>
            <RadioButton Theme="{StaticResource DateTabBtn}"
                         GroupName="CommunityDates"
                         IsChecked="{Binding IsDate202501Selected, Mode=OneWay}"
                         Command="{Binding SelectDateCommand}"
                         CommandParameter="2025-1"
                         Content="2025-1"/>
            <RadioButton Theme="{StaticResource DateTabBtn}"
                         GroupName="CommunityDates"
                         IsChecked="{Binding IsDate202508Selected, Mode=OneWay}"
                         Command="{Binding SelectDateCommand}"
                         CommandParameter="2025-8"
                         Content="2025-8"/>

            <Button Theme="{StaticResource SmallRoundBtn}"
                    IsVisible="{Binding HasLanzouLink}"
                    Command="{Binding OpenLanzouCommand}"
                    ToolTip.Tip="{Binding LanzouTooltip}"
                    Margin="10,0,0,0"
                    Padding="10"
                    Background="Transparent"
                    VerticalAlignment="Center">
                <Path Data="M652.8 473.6l-51.2-51.2-84.8 83.2V116.8h-72v388.8l-83.2-83.2-51.2 51.2 168 168 174.4-168z M188.8 833.6V427.2h72v-72h-72c-40 0-72 32-72 72v408c0 40 32 70.4 72 70.4h345.6v-72H188.8z m646.4-406.4c0-40-32-72-72-72h-72v72h72v121.6h72v-121.6zM942.4 728l-163.2-126.4c-3.2-3.2-8-4.8-12.8-4.8-11.2 0-20.8 8-20.8 19.2v60.8c-94.4 9.6-168 78.4-168 161.6 0 24 11.2 48 14.4 54.4l14.4 27.2 8-27.2c14.4-43.2 57.6-73.6 118.4-83.2h1.6c3.2 0 6.4 0 9.6-1.6v60.8c0 4.8 1.6 9.6 6.4 14.4 8 6.4 19.2 8 27.2 1.6 163.2-128 164.8-128 166.4-128l1.6-1.6c3.2-3.2 4.8-8 3.2-14.4 0-4.8-3.2-9.6-6.4-12.8z m-185.6 30.4c-9.6 0-19.2 1.6-28.8 1.6h-3.2c-27.2 4.8-52.8 12.8-75.2 24 22.4-33.6 62.4-56 110.4-57.6l40-1.6v-41.6l76.8 59.2-76.8 59.2v-44.8l-43.2 1.6z"
                      Fill="{DynamicResource SvgIconBrush}"
                      Stretch="Uniform"
                      Width="22"
                      Height="22"
                      VerticalAlignment="Center"/>
            </Button>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="10,0,10,10"
                Background="{DynamicResource CardBgBrush}"
                CornerRadius="12"
                Padding="18">
            <Grid>
                <ScrollViewer IsVisible="{Binding HasEntries}">
                    <ItemsControl ItemsSource="{Binding CurrentEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlBgBrush}"
                                        CornerRadius="8"
                                        Margin="0,0,0,10"
                                        Padding="14,12">
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource ThemeTextMainBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel IsVisible="{Binding IsEmpty}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="{Binding SelectedDate}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SvgIconBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding EmptyMessage}"
                               FontSize="14"
                               Foreground="{DynamicResource ThemeTextSubBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
