<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MdModManager.Views.MessageBox"
        Title="提示"
        Width="400" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        SystemDecorations="Full">

    <Grid RowDefinitions="Auto, Auto, Auto" Margin="24" VerticalAlignment="Center">
        <!-- 提示文本 -->
        <TextBlock x:Name="MessageText"
                   Grid.Row="0"
                   Text="提示信息"
                   TextWrapping="Wrap"
                   FontSize="15"
                   Foreground="#E0E0E0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>

        <Border x:Name="MessageImageHost"
                Grid.Row="1"
                IsVisible="False"
                Margin="0,16,0,0"
                CornerRadius="6"
                ClipToBounds="True"
                HorizontalAlignment="Center"
                Background="#111111">
            <Image x:Name="MessageImage"
                   Width="480"
                   MaxHeight="260"
                   Stretch="Uniform"/>
        </Border>

        <!-- 底部按钮区 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="16"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="取消"
                    Width="100"
                    Height="32"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    IsVisible="False"
                    Click="OnCancelClick"/>
            <Button x:Name="ConfirmButton"
                    Content="确定"
                    Width="100"
                    Height="32"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{DynamicResource ThemeAccentBrush}"
                    Foreground="White"
                    Click="OnConfirmClick"/>
        </StackPanel>
    </Grid>
</Window>
