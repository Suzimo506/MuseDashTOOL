<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MdModManager.ViewModels"
        xmlns:svc="using:MdModManager.Services"
        xmlns:helpers="using:MdModManager.Helpers"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="MdModManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="喵斯兔"
        Icon="/Assets/MuseDashTOOL.ico"
        Width="1280" Height="800"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        FontFamily="{Binding CurrentFontFamily}"
        FontSize="{Binding CurrentFontSize}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        UseLayoutRounding="True"
        CanResize="False">

    <!-- 最外层 Panel，用于在窗口左下角叠加通知气泡及最底层背景图 -->
    <Panel>

        <!-- 全局自定义背景图容器 -->
        <Grid IsHitTestVisible="False" 
              IsVisible="{Binding CustomBackgroundBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"
              Opacity="{Binding WindowOpacityValue}">
            <Image Source="{Binding CustomBackgroundBitmap}" 
                   Stretch="UniformToFill" 
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Image.Effect>
                    <BlurEffect Radius="{Binding BackgroundBlurRadius}" />
                </Image.Effect>
            </Image>
            <!-- 亮度调节遮罩层（黑色），透明度等于 1.0 - 明亮度 -->
            <Border Background="Black" Opacity="{Binding CustomBackgroundDarkness}" />
        </Grid>

        <Grid ColumnDefinitions="250, *">
            <!-- 左侧侧边栏，背景颜色由 ViewModel 动态控制 (当有背景图时透明，否则为深色) -->
            <Border Grid.Column="0" Background="{Binding SidebarBackground}" Padding="0,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Logo / Title -->
                    <!-- 将上边距增加 20 (字体高度)，使得"文字顶部"对齐右侧容器顶部(Margin=15) -->
                    <!-- 将下边距减小 20，总间距 (35+35)=70 保持与原版(30+40)一致，下方菜单不会位移 -->
                    <Button Command="{Binding GenerateLogCommand}" 
                            PointerPressed="OnTitlePointerPressed"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="20,35,20,35">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="Button:pressed /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </Button.Styles>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="喵斯兔" FontSize="22" FontWeight="Bold" LetterSpacing="3" VerticalAlignment="Bottom">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#FF00FF" Offset="0"/>
                                        <GradientStop Color="#FF69B4" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="v1.3.3" FontSize="12" Foreground="White" Margin="5,0,0,2" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Main Navigation (Top) -->
                    <StackPanel Grid.Row="1" Spacing="8" Margin="10,0">
                        <StackPanel.Styles>
                            <Style Selector="Button.NavBtn">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="MinHeight" Value="40"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="RenderTransform" Value="translateX(0px) scale(1.0)"/>
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="SineEaseOut"/>
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="Button.NavBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pointerover">
                                <Setter Property="RenderTransform" Value="translateX(10px) scale(1.05)"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pressed">
                                <Setter Property="RenderTransform" Value="translateX(0px) scale(0.95)"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:disabled /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:disabled">
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonMainBrush}"/>
                                <Setter Property="Opacity" Value="1.0"/>
                            </Style>
                        </StackPanel.Styles>
                        
                        <LayoutTransformControl>
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding FontScale}" ScaleY="{Binding FontScale}"/>
                            </LayoutTransformControl.LayoutTransform>
                            <StackPanel Spacing="10">
                                <Button Classes="NavBtn" Command="{Binding NavigateToModManagerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M821.333333 85.333333H202.666667C136.533333 85.333333 85.333333 136.533333 85.333333 202.666667v618.666666C85.333333 887.466667 136.533333 938.666667 202.666667 938.666667h618.666666c66.133333 0 117.333333-51.2 117.333334-117.333334V202.666667C938.666667 136.533333 887.466667 85.333333 821.333333 85.333333zM298.666667 768H192v-85.333333h106.666667v85.333333z m0-170.666667H192v-85.333333h106.666667v85.333333z m0-170.666666H192V341.333333h106.666667v85.333334z m533.333333 341.333333H362.666667v-85.333333h469.333333v85.333333z m0-170.666667H362.666667v-85.333333h469.333333v85.333333z m0-170.666666H362.666667V341.333333h469.333333v85.333334z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonMainBrush}"/>
                                        <TextBlock Text="Mod管理" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="NavBtn" Command="{Binding NavigateToChartManagerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M768 128H256c-70.4 0-128 57.6-128 128v512c0 70.4 57.6 128 128 128h512c70.4 0 128-57.6 128-128V256c0-70.4-57.6-128-128-128z m42.666667 640c0 23.466667-19.2 42.666667-42.666667 42.666667H256c-23.466667 0-42.666667-19.2-42.666667-42.666667V256c0-23.466667 19.2-42.666667 42.666667-42.666667h512c23.466667 0 42.666667 19.2 42.666667 42.666667v512zM341.333333 362.666667h341.333334v85.333333H341.333333V362.666667z m0 213.333333h341.333334v85.333333H341.333333v-85.333333z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonMainBrush}"/>
                                        <TextBlock Text="谱面管理" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Spacing="4">
                                    <Button Classes="NavBtn" Command="{Binding ToggleChartDownloadMenuCommand}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                                            <PathIcon Grid.Column="0"
                                                      Data="M498.347 824.32l-296.96-296.96c-11.947-11.947-3.414-34.133 13.653-34.133h160.427c11.946 0 20.48-8.534 20.48-20.48V54.613c0-11.946 8.533-20.48 20.48-20.48h189.44c11.946 0 20.48 8.534 20.48 20.48v418.134c0 11.946 8.533 20.48 20.48 20.48h160.426c18.774 0 27.307 22.186 13.654 34.133L525.653 824.32c-6.826 6.827-20.48 6.827-27.306 0zM916.48 989.867H107.52c-18.773 0-35.84-15.36-35.84-35.84 0-18.774 15.36-35.84 35.84-35.84h810.667c18.773 0 35.84 15.36 35.84 35.84-1.707 20.48-17.067 35.84-37.547 35.84z"
                                                      Width="18" Height="18"
                                                      Foreground="{DynamicResource NavButtonMainBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="谱面下载"
                                                       LetterSpacing="{Binding NavButtonLetterSpacing}"
                                                       VerticalAlignment="Center"/>
                                            <Panel Grid.Column="2" Width="13" Height="13" VerticalAlignment="Center">
                                                <PathIcon Data="M256 384l256 256 256-256z"
                                                          Width="13"
                                                          Height="13"
                                                          Foreground="{DynamicResource NavButtonMainBrush}"
                                                          IsVisible="{Binding !IsChartDownloadMenuExpanded}"/>
                                                <PathIcon Data="M256 640l256-256 256 256z"
                                                          Width="13"
                                                          Height="13"
                                                          Foreground="{DynamicResource NavButtonMainBrush}"
                                                          IsVisible="{Binding IsChartDownloadMenuExpanded}"/>
                                            </Panel>
                                        </Grid>
                                    </Button>
                                    <StackPanel Spacing="4"
                                                Margin="18,0,0,0"
                                                IsVisible="{Binding IsChartDownloadMenuExpanded}">
                                        <Button Classes="NavBtn" Command="{Binding NavigateToChartDownloadCommand}">
                                            <TextBlock Text="mdmc谱面" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                        </Button>
                                        <Button Classes="NavBtn" Command="{Binding NavigateToAlbumCollectionCommand}">
                                            <TextBlock Text="QQ群谱面" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                <!-- <Button Classes="NavBtn" Command="{Binding NavigateToChartUploadCommand}"><TextBlock Text="谱面上传" LetterSpacing="{Binding NavButtonLetterSpacing}"/></Button> -->
                                <Button Classes="NavBtn" Command="{Binding NavigateToConfigManagerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M170.666667 213.333333h682.666666v85.333334H170.666667V213.333333z m0 256h682.666666v85.333334H170.666667v-85.333334z m0 256h682.666666v85.333334H170.666667v-85.333334z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonMainBrush}"/>
                                        <TextBlock Text="配置文件" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="NavBtn" Command="{Binding NavigateToAccountCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M512 128a192 192 0 1 0 192 192A192 192 0 0 0 512 128z m0 469.333333c-128 0-384 64-384 192v42.666667h768v-42.666667c0-128-256-192-384-192z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonMainBrush}"/>
                                        <TextBlock Text="我的账号" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="NavBtn" Command="{Binding NavigateToTutorialCommand}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <PathIcon Data="M512 85.333333C276.266667 85.333333 85.333333 276.266667 85.333333 512s190.933333 426.666667 426.666667 426.666667 426.666667-190.933333 426.666667-426.666667S747.733333 85.333333 512 85.333333z m42.666667 640h-85.333334v-256h85.333334v256z m0-341.333333h-85.333334v-85.333333h85.333334v85.333333z"
                                                      Width="18" Height="18"
                                                      Foreground="{DynamicResource NavButtonMainBrush}"/>
                                            <TextBlock Text="使用说明" LetterSpacing="{Binding NavButtonLetterSpacing}"/>
                                        </StackPanel>
                                        <!-- 红点提示：有新内容时显示，点击后消失 -->
                                        <Ellipse Width="8" Height="8" Fill="#FF4444"
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,-2,-12,0"
                                                 IsVisible="{Binding ShowTutorialBadge}">
                                            <Ellipse.Styles>
                                                <Style Selector="Ellipse">
                                                    <Style.Animations>
                                                        <Animation Duration="0:0:1.5" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                                            <KeyFrame Cue="0%">
                                                                <Setter Property="Opacity" Value="1.0"/>
                                                            </KeyFrame>
                                                            <KeyFrame Cue="100%">
                                                                <Setter Property="Opacity" Value="0.3"/>
                                                            </KeyFrame>
                                                        </Animation>
                                                    </Style.Animations>
                                                </Style>
                                            </Ellipse.Styles>
                                        </Ellipse>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </LayoutTransformControl>
                    </StackPanel>

                    <!-- Footer Navigation (Bottom) -->
                    <StackPanel Grid.Row="2" Spacing="8" Margin="10,0,10,20">
                        <StackPanel.Styles>
                            <Style Selector="Button.NavBtn">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="MinHeight" Value="42"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="RenderTransform" Value="translateX(0px) scale(1.0)"/>
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="SineEaseOut"/>
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="Button.NavBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pointerover">
                                <Setter Property="RenderTransform" Value="translateX(10px) scale(1.05)"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:pressed">
                                <Setter Property="RenderTransform" Value="translateX(0px) scale(0.95)"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:disabled /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                            </Style>
                            <Style Selector="Button.NavBtn:disabled">
                                <Setter Property="Foreground" Value="{DynamicResource NavButtonSubBrush}"/>
                                <Setter Property="Opacity" Value="1.0"/>
                            </Style>
                        </StackPanel.Styles>
                        
                        <!-- 启动/重启游戏按钮 + 暂存 Mod 提醒 -->
                        <LayoutTransformControl>
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding FontScale}" ScaleY="{Binding FontScale}"/>
                            </LayoutTransformControl.LayoutTransform>
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0" Classes="NavBtn" Command="{Binding LaunchGameCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <PathIcon Data="M896 512L128 1024V0z"
                                                      Width="18" Height="18"
                                                      Foreground="{DynamicResource NavButtonSubBrush}"/>
                                            <TextBlock Text="启动/重启游戏"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Grid.Column="1"
                                               Text="!!!"
                                               IsVisible="{Binding HasStagedMods}"
                                               Foreground="{DynamicResource ThemeTextMainBrush}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="4,0,8,0"
                                               ToolTip.Tip="有 Mod 已暂存，将在游戏关闭后自动安装"/>
                                </Grid>
                                <Button Classes="NavBtn" Command="{Binding NavigateToMelonLoaderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M128 256h768v85.333333H128V256z m85.333333 213.333333h597.333334v85.333334H213.333333v-85.333334z m128 213.333334h341.333334v85.333333H341.333333v-85.333333z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonSubBrush}"/>
                                        <TextBlock Text="MelonLoader 管理"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="NavBtn" Command="{Binding NavigateToSettingsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M896 554.666667v-85.333334l-94.293333-12.373333a292.266667 292.266667 0 0 0-24.746667-59.733333l57.173333-76.373334-60.373333-60.373333-76.373333 57.173333a292.266667 292.266667 0 0 0-59.733334-24.746666L554.666667 128h-85.333334l-12.373333 94.293333a292.266667 292.266667 0 0 0-59.733333 24.746667l-76.373334-57.173333-60.373333 60.373333 57.173333 76.373333a292.266667 292.266667 0 0 0-24.746666 59.733334L128 469.333333v85.333334l94.293333 12.373333a292.266667 292.266667 0 0 0 24.746667 59.733333l-57.173333 76.373334 60.373333 60.373333 76.373333-57.173333a292.266667 292.266667 0 0 0 59.733334 24.746666L469.333333 896h85.333334l12.373333-94.293333a292.266667 292.266667 0 0 0 59.733333-24.746667l76.373334 57.173333 60.373333-60.373333-57.173333-76.373333a292.266667 292.266667 0 0 0 24.746666-59.733334L896 554.666667zM512 682.666667a170.666667 170.666667 0 1 1 170.666667-170.666667 170.666667 170.666667 0 0 1-170.666667 170.666667z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonSubBrush}"/>
                                        <TextBlock Text="设置"/>
                                    </StackPanel>
                                </Button>
                                
                                <Border Height="1" Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.2" Margin="10,10,10,5"/>
                                <Button Classes="NavBtn" Click="OnSelectGamePathClick">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <PathIcon Data="M928 352v-48c0-35.3-28.7-64-64-64H485.2c-21 0-40.7-10.3-52.6-27.6l-61.5-88.9c-12-17.3-31.6-27.6-52.6-27.6H64c-35.3 0-64 28.7-64 64v656c0 70.7 57.3 128 128 128h638c57.8 0 108.5-38.8 123.6-94.6L928 707.2l74.2-274.5c11-40.7-19.6-80.7-61.8-80.7H928z"
                                                  Width="18" Height="18"
                                                  Foreground="{DynamicResource NavButtonSubBrush}"/>
                                        <TextBlock Text="选择游戏目录"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </LayoutTransformControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <!-- 内容区域的背景由 ViewModel 动态控制，背景扩大以覆盖顶部无背景导致色差的问题 -->
            <Border Grid.Column="1" Background="{Binding ContentBackground}">
                <LayoutTransformControl Margin="20,55,35,35">
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding FontScale}" ScaleY="{Binding FontScale}"/>
                    </LayoutTransformControl.LayoutTransform>
                    <ContentControl Content="{Binding CurrentPage}"/>
                </LayoutTransformControl>
            </Border>
        </Grid>

        <!-- 全局公告弹窗遮罩 -->
        <Grid IsVisible="{Binding IsAnnouncementVisible}" Background="#AA000000">
            <Border Width="450" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#2A2A2A" CornerRadius="12" Padding="25"
                    BoxShadow="0 10 30 0 #50000000">
                <StackPanel Spacing="20">
                    <!-- 标题：粉色渐变 -->
                    <TextBlock Text="{Binding CurrentAnnouncement.Title}"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#FF69B4" Offset="0"/>
                                <GradientStop Color="#d4237a" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <!-- 内容：从 NoticeInfo 获取 -->
                    <ScrollViewer MaxHeight="300">
                        <TextBlock helpers:TextBlockHelper.MarkupText="{Binding CurrentAnnouncement.Content}"
                                   TextWrapping="Wrap" LineHeight="24" FontSize="14"
                                   Foreground="{DynamicResource ThemeTextMainBrush}"
                                   Opacity="0.9"/>
                    </ScrollViewer>

                    <Separator Background="{DynamicResource ThemeTextSubBrush}" Opacity="0.1"/>

                    <!-- 底部操作栏 -->
                    <Grid ColumnDefinitions="*,Auto">
                        <CheckBox Grid.Column="0" 
                                  IsChecked="False"
                                  Command="{Binding SuppressAndCloseAnnouncementCommand}"
                                  Content="{Binding CurrentAnnouncement.CancelButtonText}"
                                  FontSize="13" Foreground="#A0A0A0">
                            <CheckBox.Styles>
                                <Style Selector="CheckBox /template/ Border#NormalRectangle">
                                    <Setter Property="BorderBrush" Value="#d4237a"/>
                                </Style>
                                <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                                    <Setter Property="Background" Value="#d4237a"/>
                                    <Setter Property="BorderBrush" Value="#d4237a"/>
                                </Style>
                            </CheckBox.Styles>
                        </CheckBox>
                        
                        <Button Grid.Column="1" 
                                Command="{Binding CloseAnnouncementCommand}"
                                Width="140" Height="42"
                                CornerRadius="21"
                                Background="#d4237a"
                                Foreground="White">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#FF69B4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </Button.Styles>
                            <TextBlock Text="{Binding CurrentAnnouncement.ActionButtonText}" 
                                       FontWeight="Bold" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
        <!-- 全局通知气泡：叠加在最上层 -->
        <ItemsControl ItemsSource="{Binding Notifications}"
                      VerticalAlignment="Bottom" HorizontalAlignment="Left"
                      Margin="20,0,0,20"
                      IsHitTestVisible="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Spacing="10"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="15,10" Opacity="{Binding Opacity}"
                            BoxShadow="0 4 12 0 #40000000">
                        <Border.Background>
                            <Binding Path="IsSuccess">
                                <Binding.Converter>
                                    <helpers:BoolToBrushConverter TrueBrush="#E8F5E9" FalseBrush="#FFEBEE"/>
                                </Binding.Converter>
                            </Binding>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <!-- 根据状态显示不同图标 -->
                            <Path IsVisible="{Binding IsSuccess}" Data="M512 0a512 512 0 1 0 512 512A512 512 0 0 0 512 0z m255.488 387.584L452.928 705.408a46.208 46.208 0 0 1-65.792 0L256.512 574.912a46.208 46.208 0 1 1 65.792-65.792L420 606.528l281.28-284.736a46.208 46.208 0 0 1 66.208 65.792z"
                                  Fill="#4CAF50" Width="18" Height="18" Stretch="Uniform"/>
                            <Path IsVisible="{Binding IsInfo}" Data="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64z m0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372z m28-564h-56v312h56V320z m0 384h-56v56h56v-56z"
                                  Fill="#2196F3" Width="18" Height="18" Stretch="Uniform"/>
                            <Path Data="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64z m165.4 548.2c1.4 1.4 2.1 3.2 2.1 5.1s-0.7 3.7-2.1 5.1L637 662.8c-1.4 1.4-3.2 2.1-5.1 2.1s-3.7-0.7-5.1-2.1L512 547.9 397.1 662.8c-1.4 1.4-3.2 2.1-5.1 2.1s-3.7-0.7-5.1-2.1L346.5 622.4c-1.4-1.4-2.1-3.2-2.1-5.1s0.7-3.7 2.1-5.1L461.4 512 346.5 397.1c-1.4-1.4-2.1-3.2-2.1-5.1s0.7-3.7 2.1-5.1l40.4-40.4c1.4-1.4 3.2-2.1 5.1-2.1s3.7 0.7 5.1 2.1L512 476.1l114.9-114.9c1.4-1.4 3.2-2.1 5.1-2.1s3.7 0.7 5.1 2.1l40.4 40.4c1.4 1.4 2.1 3.2 2.1 5.1s-0.7 3.7-2.1 5.1L562.6 512l114.8 114.8z"
                                  Fill="#F44336" Width="18" Height="18" Stretch="Uniform">
                                <Path.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="!IsSuccess"/>
                                        <Binding Path="!IsInfo"/>
                                    </MultiBinding>
                                </Path.IsVisible>
                            </Path>

                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Message}" FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <Binding Path="IsSuccess">
                                            <Binding.Converter>
                                                <helpers:BoolToBrushConverter TrueBrush="#2E7D32" FalseBrush="#C62828"/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <ProgressBar IsVisible="{Binding ShowProgress}" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="4" Foreground="#d4237a" HorizontalAlignment="Stretch" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Panel>
</Window>
